# Vercel KV (Redis) - Set automatically when you create KV in Vercel Dashboard
# Go to: Vercel Dashboard → Storage → Create Database → KV → Create
# Vercel will auto-set these two variables:
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Push Notification VAPID Keys (set in Vercel Dashboard → Settings → Environment Variables)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:forexyemeni@push.local

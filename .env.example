# ============================================
# TradeSignal Pro - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values

# PostgreSQL Database URL (Neon / Supabase / any PostgreSQL)
# Get a FREE database at: https://neon.tech
#
# For Neon, use the pooled connection URL for production:
# DATABASE_URL="postgresql://user:password@ep-xxx.region.neon.tech/dbname?sslmode=require&pgbouncer=true"
#
# For local development with Neon:
# DATABASE_URL="postgresql://user:password@ep-xxx.region.neon.tech/dbname?sslmode=require"
DATABASE_URL="postgresql://user:password@localhost:5432/tradesignal?schema=public"

# Optional: App URL (for CORS if needed)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

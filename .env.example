# Vercel KV (Redis) - Set automatically when you create KV in Vercel Dashboard
# Go to: Vercel Dashboard → Storage → Create Database → KV → Create
# Vercel will auto-set these two variables:
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Push Notification VAPID Keys (set in Vercel Dashboard → Settings → Environment Variables)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:forexyemeni@push.local

# Email via Google Apps Script (FREE — uses Gmail)
# 1. Create new Google Apps Script project
# 2. Paste code from google-apps-script/Email-Sender.js
# 3. Deploy → New deployment → Web app → Anyone can access
# 4. Copy the Web app URL below
GOOGLE_APPS_SCRIPT_EMAIL_URL=
# Optional: API key for authentication (set same value in Email-Sender.js)
GOOGLE_APPS_SCRIPT_EMAIL_KEY=

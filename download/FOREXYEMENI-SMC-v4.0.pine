//@version=5
indicator("FOREXYEMENI-SMC-v4.0", shorttitle="FYP-SMC", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=500)

//═══════════════════════════════════════════════
//  1. الإعدادات
//═══════════════════════════════════════════════
grp1 = "1️⃣ إعدادات SMC / ICT"
swingLen   = input.int(5,      "📏 حساسية السوينج", minval=2, maxval=20, group=grp1)
dispMult   = input.float(1.5,  "🔄 معامل الإزاحة", step=0.1, group=grp1)
bodyAvgLen = input.int(20,     "📊 متوسط جسم الشمعة", group=grp1)
useOBEntry = input.bool(true,  "🧱 دخول من أوردر بلوك", group=grp1)
useFVGEntry= input.bool(true,  "📦 دخول من FVG", group=grp1)
useSweep   = input.bool(true,  "🌊 دخول من تنظيف السيولة", group=grp1)
useCHoCH   = input.bool(true,  "🔄 دخول من CHoCH", group=grp1)
useBOSEntry= input.bool(true,  "⚡ دخول من BOS", group=grp1)
useOTE     = input.bool(true,  "🎯 دخول من OTE (0.62-0.79)", group=grp1)
candleConf = input.bool(true,  "🕯️ تأكيد الشمعة", group=grp1)
zoneExpiry = input.int(50,     "⏰ انتهاء المنطقة (شموع)", minval=10, maxval=200, group=grp1)
minStars   = input.int(1,      "⭐ حد أدنى نجوم", minval=1, maxval=3, group=grp1)

grp2 = "2️⃣ HTF"
useAutoHTF = input.bool(true,  "🤖 HTF تلقائي", group=grp2)
manualHTF  = input.timeframe("60", "⏱️ HTF يدوي", group=grp2)

grp3 = "3️⃣ الأهداف والوقف"
numTP   = input.int(5,    "🔢 عدد الأهداف", minval=1, maxval=10, group=grp3)
slBuffer= input.float(1.0,"📏 هامش الوقف (نقاط)", step=0.1, group=grp3)
useTrail= input.bool(false,"🚀 وقف تتبعي", group=grp3)
beBuf   = input.float(0.5, "🛡️ هامش التأمين (نقاط)", step=0.1, group=grp3)

grp4 = "4️⃣ إدارة المخاطر"
bal   = input.float(1000.0, "💵 الرصيد ($)", step=100, minval=1, group=grp4)
riskP = input.float(1.0,    "⚠️ المخاطرة %", step=0.1, minval=0.1, maxval=100, group=grp4)

grp5 = "5️⃣ التعزيز والتعويض"
usePyr   = input.bool(true,  "🔥 تعزيز", group=grp5)
pyrTP    = input.int(3,      "🔢 أهداف التعزيز", minval=1, maxval=5, group=grp5)
pyrRR    = input.float(1.5,  "🎯 R:R التعزيز", group=grp5)
useReentry= input.bool(false,"♻️ صفقة تعويض", group=grp5)
reMult   = input.float(1.5,  "➗ مضاعف وقف التعويض", group=grp5)
reTPn    = input.int(5,      "🔢 أهداف تعويض", minval=1, maxval=10, group=grp5)

grp6 = "6️⃣ الإحصائيات والمظهر"
showOB      = input.bool(true,  "🧱 إظهار Order Blocks", group=grp6)
showFVG     = input.bool(true,  "📦 إظهار FVG", group=grp6)
showSwing   = input.bool(true,  "📍 إظهار نقاط السوينج", group=grp6)
showBOS     = input.bool(true,  "⚡ إظهار BOS/CHoCH", group=grp6)
showTradeBG = input.bool(true,  "🎨 خلفية الصفقة", group=grp6)
showEntryMark= input.bool(true, "📌 علامة الدخول", group=grp6)
statPeriod  = input.string("اليوم الحالي (مكة)", "📅 فترة الإحصائيات", options=["اليوم الحالي (مكة)","آخر 7 أيام","آخر 30 يوم","كل البيانات"], group=grp6)

//═══════════════════════════════════════════════
//  2. HTF تلقائي
//═══════════════════════════════════════════════
getHTF() =>
    string r = ""
    if timeframe.isseconds
        r := "5"
    else if timeframe.isminutes
        r := timeframe.multiplier <= 1 ? "15" : timeframe.multiplier <= 5 ? "60" : timeframe.multiplier <= 15 ? "240" : timeframe.multiplier <= 60 ? "D" : "W"
    else if timeframe.isdaily
        r := "W"
    else if timeframe.isweekly
        r := "M"
    else
        r := "D"
    r

htfName(string tf) =>
    tf == "60" ? "1س" : tf == "240" ? "4س" : tf == "D" ? "يومي" : tf == "W" ? "أسبوعي" : tf

string autoHTF = getHTF()
string htf     = useAutoHTF ? autoHTF : manualHTF
string htfD    = useAutoHTF ? htfName(autoHTF) : htfName(manualHTF)

//═══════════════════════════════════════════════
//  3. كشف الأداة
//═══════════════════════════════════════════════
getInst() =>
    string t = syminfo.ticker
    string r = "فوركس"
    if str.contains(t,"XAU") or str.contains(t,"GOLD")
        r := "الذهب (XAUUSD)"
    else if str.contains(t,"XAG") or str.contains(t,"SILVER")
        r := "الفضة (XAGUSD)"
    else if str.contains(t,"BTC") or str.contains(t,"ETH") or str.contains(t,"SOL") or str.contains(t,"BNB") or str.contains(t,"XRP") or str.contains(t,"ADA") or str.contains(t,"DOGE") or str.contains(t,"DOT") or str.contains(t,"USDT")
        r := "عملات رقمية"
    else if str.contains(t,"NAS") or str.contains(t,"US30") or str.contains(t,"DAX") or str.contains(t,"US500") or str.contains(t,"SPX") or str.contains(t,"NDX")
        r := "مؤشرات (NAS/DOW)"
    else if str.contains(t,"JPY")
        r := "فوركس (6 أرقام)"
    r

string inst = getInst()

getInstShort() =>
    string t = syminfo.ticker
    string r = "فوركس"
    if str.contains(t,"XAU") or str.contains(t,"GOLD")
        r := "🥇 ذهب"
    else if str.contains(t,"XAG") or str.contains(t,"SILVER")
        r := "🥈 فضة"
    else if str.contains(t,"BTC") or str.contains(t,"ETH") or str.contains(t,"SOL")
        r := "₿ كريبتو"
    else if str.contains(t,"NAS") or str.contains(t,"US30") or str.contains(t,"DAX")
        r := "📊 مؤشرات"
    else if str.contains(t,"JPY")
        r := "💱 فوركس JPY"
    r

string instShort = getInstShort()

//═══════════════════════════════════════════════
//  4. الألوان
//═══════════════════════════════════════════════
color cG  = color.new(#00E676, 0)
color cR  = color.new(#FF5252, 0)
color cO  = color.new(#FF9800, 0)
color cAu = color.new(#FFD700, 0)
color cCy = color.new(#00BCD4, 0)
color cGr = color.new(color.gray, 0)
color cBG = color.new(#1E222D, 10)
color cP  = color.new(#E040FB, 0)
color cBl = color.new(#2962FF, 0)

var color[] tpC = array.from(color.new(#2962FF,0), color.new(#00897B,0), color.new(#00BCD4,0), color.new(#009688,0), color.new(#4CAF50,0), color.new(#8BC34A,0), color.new(#CDDC39,0), color.new(#FFEB3B,0), color.new(#FFC107,0), color.new(#FF9800,0))

string SEP = "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

//═══════════════════════════════════════════════
//  5. دوال الحساب
//═══════════════════════════════════════════════
slValPerLot(float d) =>
    math.max(d / syminfo.mintick * syminfo.pointvalue, 0.0001)

calcLot(float risk, float dist) =>
    math.min(math.max(math.floor(risk / slValPerLot(dist) * 100.0) / 100.0, 0.01), 100.0)

pnlD(float lot, float dist) =>
    slValPerLot(dist) * lot

beBufPx() =>
    beBuf * syminfo.mintick * 10.0

lotStr(float l) =>
    l >= 1.0 ? str.tostring(math.round(l,2),"#.##") + " لوت" : l >= 0.1 ? str.tostring(math.round(l,2),"#.##") + " ميني" : str.tostring(math.round(l,2),"#.##") + " مايكرو"

//═══════════════════════════════════════════════
//  6. متغيرات الصفقة الرئيسية
//═══════════════════════════════════════════════
var int   totT = 0, var int   winT = 0, var int lossT = 0
var int   reWin= 0, var int   reLoss= 0, var int lastExit= 0
var bool  tradeCnt = false
var float ep = na, var float sl = na, var float iSL = na
var float mxTP = na
var float sLot= 0.0, var float sRisk= 0.0
var bool  sIsBuy= true, var bool inT= false, var bool isBuy= false
var bool  slSent=false, var bool pyrSent=false, var bool beSent=false
var int   mxTPR= 0, var int   laTP2= 0, var int  stars= 0
var string sigType= "", var int entryTime= na
var int   lastSig= 0

var line  eL= na, var line  slL= na
var label eLb=na, var label slLb=na

var float[] tpP = array.new_float()
var line[]  tpL = array.new_line()
var label[] tpLb= array.new_label()
var bool[]  tpS = array.new_bool()

//═══════════════════════════════════════════════
//  7. متغيرات التعزيز
//═══════════════════════════════════════════════
var bool  inPy=false, var float pyE=na, var float pySL=na
var float pyLot= 0.0
var int   pyrR= 0, var int pyrLA=0, var bool pyrSLAS=false
var line  pyEL=na, var line pySLL=na
var label pyELb=na, var label pySLb=na
var float[] pyTP= array.new_float()
var line[]  pyTL= array.new_line()
var label[] pyTLb=array.new_label()
var bool[]  pyTS= array.new_bool()

//═══════════════════════════════════════════════
//  8. متغيرات التعويض
//═══════════════════════════════════════════════
var bool  inRe=false, var bool pendRe=false, var bool reCnt=false
var float reE=na, var float reSL=na
var float reLot=0.0, var int reR=0, var int reLA=0
var bool isBuyRe=false, var bool reSLS=false
var line reEL=na, var line reSLL=na
var label reELb=na, var label reSLb=na
var float[] reTP= array.new_float()
var line[]  reTL= array.new_line()
var label[] reTLb=array.new_label()
var bool[]  reTS= array.new_bool()

//═══════════════════════════════════════════════
//  9. إحصائيات
//═══════════════════════════════════════════════
var int[] tCTime= array.new_int()
var int[] tCWin = array.new_int()

//═══════════════════════════════════════════════
//  10. SMC: كشف السوينج
//═══════════════════════════════════════════════
float ph = ta.pivothigh(high, swingLen, swingLen)
float pl = ta.pivotlow (low,  swingLen, swingLen)

var float sh1=na, var float sh2=na, var float sh3=na
var float sl1=na, var float sl2=na, var float sl3=na
var int sh1Bar=0, var int sl1Bar=0

if not na(ph)
    sh3 := sh2
    sh2 := sh1
    sh1 := ph
    sh1Bar := bar_index - swingLen

if not na(pl)
    sl3 := sl2
    sl2 := sl1
    sl1 := pl
    sl1Bar := bar_index - swingLen

var float[] allSH = array.new_float()
var float[] allSL = array.new_float()

if not na(ph)
    array.push(allSH, ph)
    if array.size(allSH) > 50
        array.shift(allSH)
if not na(pl)
    array.push(allSL, pl)
    if array.size(allSL) > 50
        array.shift(allSL)

//═══════════════════════════════════════════════
//  11. SMC: هيكل السوق (HH/HL/LH/LL)
//═══════════════════════════════════════════════
var int structDir = 0

if not na(sh2) and not na(sh1) and not na(sl2) and not na(sl1)
    if sh1 > sh2 and sl1 > sl2
        structDir := 1
    else if sh1 < sh2 and sl1 < sl2
        structDir := -1

// BOS: كسر آخر سوينج في اتجاه الاتجاه
bool bosBull = false
bool bosBear = false
if barstate.isconfirmed and not inT
    if structDir == 1 and not na(sh1) and close > sh1
        bosBull := true
    if structDir == -1 and not na(sl1) and close < sl1
        bosBear := true

// CHoCH: كسر آخر سوينج عكس الاتجاه الحالي
bool chochBull = false
bool chochBear = false
if barstate.isconfirmed and not inT
    if structDir == -1 and not na(sh1) and close > sh1
        chochBull := true
        structDir := 1
    if structDir == 1 and not na(sl1) and close < sl1
        chochBear := true
        structDir := -1

//═══════════════════════════════════════════════
//  12. SMC: كشف الإزاحة (Displacement)
//═══════════════════════════════════════════════
float avgBody = ta.sma(math.abs(close - open), bodyAvgLen)
bool bullDisp = barstate.isconfirmed and (close - open) > avgBody * dispMult and close > high[1]
bool bearDisp = barstate.isconfirmed and (open - close) > avgBody * dispMult and close < low[1]

//═══════════════════════════════════════════════
//  13. SMC: منطقة أوردر بلوك
//═══════════════════════════════════════════════
var float obTop=na, var float obBot=na
var bool obActive=false, var bool obBull=false
var int obBar=0
var box obBox=na

if bullDisp and not obActive
    obTop := math.max(open[1], close[1])
    obBot := math.min(open[1], close[1])
    obBull := true
    obActive := true
    obBar := bar_index
    if showOB
        if not na(obBox)
            box.delete(obBox)
        obBox := box.new(bar_index-1, obTop, bar_index+20, obBot, bgcolor=color.new(#00E676,85), border_color=color.new(#00E676,50), text="OB+", text_size=size.tiny)

if bearDisp and not obActive
    obTop := math.max(open[1], close[1])
    obBot := math.min(open[1], close[1])
    obBull := false
    obActive := true
    obBar := bar_index
    if showOB
        if not na(obBox)
            box.delete(obBox)
        obBox := box.new(bar_index-1, obTop, bar_index+20, obBot, bgcolor=color.new(#FF1744,85), border_color=color.new(#FF1744,50), text="OB-", text_size=size.tiny)

if obActive
    if obBull and low < obBot
        obActive := false
        if showOB and not na(obBox)
            box.delete(obBox)
    if not obBull and high > obTop
        obActive := false
        if showOB and not na(obBox)
            box.delete(obBox)
    if bar_index - obBar > zoneExpiry
        obActive := false
        if showOB and not na(obBox)
            box.delete(obBox)

//═══════════════════════════════════════════════
//  14. SMC: منطقة FVG
//═══════════════════════════════════════════════
var float fvgTop=na, var float fvgBot=na
var bool fvgActive=false, var bool fvgBull=false
var int fvgBar=0
var box fvgBox=na

bool bf  = barstate.isconfirmed and low > high[2]
bool bf2 = barstate.isconfirmed and high < low[2]

if bf and not obActive and not fvgActive
    fvgTop := low
    fvgBot := high[2]
    fvgBull := true
    fvgActive := true
    fvgBar := bar_index
    if showFVG
        if not na(fvgBox)
            box.delete(fvgBox)
        fvgBox := box.new(bar_index-2, fvgTop, bar_index+10, fvgBot, bgcolor=color.new(#00E676,90), border_color=color.new(#00E676,50), text="FVG+", text_size=size.tiny)

if bf2 and not obActive and not fvgActive
    fvgTop := low[2]
    fvgBot := high
    fvgBull := false
    fvgActive := true
    fvgBar := bar_index
    if showFVG
        if not na(fvgBox)
            box.delete(fvgBox)
        fvgBox := box.new(bar_index-2, fvgTop, bar_index+10, fvgBot, bgcolor=color.new(#FF1744,90), border_color=color.new(#FF1744,50), text="FVG-", text_size=size.tiny)

if fvgActive
    if fvgBull and close < fvgBot
        fvgActive := false
        if showFVG and not na(fvgBox)
            box.delete(fvgBox)
    if not fvgBull and close > fvgTop
        fvgActive := false
        if showFVG and not na(fvgBox)
            box.delete(fvgBox)
    if bar_index - fvgBar > zoneExpiry
        fvgActive := false
        if showFVG and not na(fvgBox)
            box.delete(fvgBox)

//═══════════════════════════════════════════════
//  15. SMC: تنظيف السيولة (Liquidity Sweep)
//═══════════════════════════════════════════════
var float sweepLevel=na
var bool sweepBull=false, var bool sweepBear=false

float tolerance = syminfo.mintick * 5.0

if not na(sh1) and not na(sh2)
    float eqH = math.abs(sh1 - sh2) < tolerance ? sh1 : na
    if not na(eqH)
        if high > eqH and close < eqH and barstate.isconfirmed
            sweepBull := true
            sweepLevel := eqH

if not na(sl1) and not na(sl2)
    float eqL = math.abs(sl1 - sl2) < tolerance ? sl1 : na
    if not na(eqL)
        if low < eqL and close > eqL and barstate.isconfirmed
            sweepBear := true
            sweepLevel := eqL

//═══════════════════════════════════════════════
//  16. SMC: OTE (Optimal Trade Entry) ICT
//═══════════════════════════════════════════════
var float oteTop=na, var float oteBot=na
var bool oteActive=false, var bool oteBull=false

if not na(sh1) and not na(sl1) and sh1 > sl1 and barstate.isconfirmed
    float range = sh1 - sl1
    float f62 = sl1 + range * 0.618
    float f79 = sl1 + range * 0.786
    oteTop := f62
    oteBot := f79
    oteBull := true
    oteActive := true

if not na(sh1) and not na(sl1) and sl1 > sh1 and barstate.isconfirmed
    float range = sl1 - sh1
    float f62 = sh1 + range * 0.618
    float f79 = sh1 + range * 0.786
    oteTop := f62
    oteBot := f79
    oteBull := false
    oteActive := true

if barstate.isconfirmed
    oteActive := false

//═══════════════════════════════════════════════
//  17. SMC: إشارات الدخول (بدون ATR!)
//═══════════════════════════════════════════════
bool bullCC = not candleConf or (close > open and close > (high + low) / 2)
bool bearCC = not candleConf or (close < open and close < (high + low) / 2)

// دخول 1: أوردر بلوك
bool obBuyEntry = false, bool obSellEntry = false
if obActive and barstate.isconfirmed and not inT
    if obBull and low <= obTop and close >= obBot and bullCC
        obBuyEntry := true
    if not obBull and high >= obBot and close <= obTop and bearCC
        obSellEntry := true

// دخول 2: FVG
bool fvgBuyEntry = false, bool fvgSellEntry = false
if fvgActive and barstate.isconfirmed and not inT
    if fvgBull and low <= fvgTop and close >= fvgBot and bullCC
        fvgBuyEntry := true
    if not fvgBull and high >= fvgBot and close <= fvgTop and bearCC
        fvgSellEntry := true

// دخول 3: تنظيف سيولة + إزاحة
bool sweepBuyEntry = false, bool sweepSellEntry = false
if barstate.isconfirmed and not inT
    if sweepBull and bullDisp
        sweepBuyEntry := true
    if sweepBear and bearDisp
        sweepSellEntry := true

// دخول 4: CHoCH + إعادة اختبار
bool chochBuyEntry = false, bool chochSellEntry = false
if barstate.isconfirmed and not inT
    if chochBull and not na(sh1) and low <= sh1 and close > sh1 and bullCC
        chochBuyEntry := true
    if chochBear and not na(sl1) and high >= sl1 and close < sl1 and bearCC
        chochSellEntry := true

// دخول 5: BOS + سحب
bool bosBuyEntry = false, bool bosSellEntry = false
if barstate.isconfirmed and not inT
    if bosBull and not na(sh1) and bar_index > sh1Bar + swingLen + 1 and low <= sh1 * 1.001 and close > sh1 and bullCC
        bosBuyEntry := true
    if bosBear and not na(sl1) and bar_index > sl1Bar + swingLen + 1 and high >= sl1 * 0.999 and close < sl1 and bearCC
        bosSellEntry := true

// دخول 6: OTE
bool oteBuyEntry = false, bool oteSellEntry = false
if oteActive and barstate.isconfirmed and not inT
    if oteBull and low <= oteTop and close >= oteBot and bullCC
        oteBuyEntry := true
    if not oteBull and high >= oteTop and close <= oteBot and bearCC
        oteSellEntry := true

// تجميع الإشارات
bool buySignal  = (useOBEntry and obBuyEntry) or (useFVGEntry and fvgBuyEntry) or (useSweep and sweepBuyEntry) or (useCHoCH and chochBuyEntry) or (useBOSEntry and bosBuyEntry) or (useOTE and oteBuyEntry)
bool sellSignal = (useOBEntry and obSellEntry) or (useFVGEntry and fvgSellEntry) or (useSweep and sweepSellEntry) or (useCHoCH and chochSellEntry) or (useBOSEntry and bosSellEntry) or (useOTE and oteSellEntry)

// تحديد نوع الإشارة
string cSigType = ""
if buySignal
    cSigType := obBuyEntry ? "OB" : fvgBuyEntry ? "FVG" : sweepBuyEntry ? "Sweep" : chochBuyEntry ? "CHoCH" : bosBuyEntry ? "BOS" : "OTE"
if sellSignal
    cSigType := obSellEntry ? "OB" : fvgSellEntry ? "FVG" : sweepSellEntry ? "Sweep" : chochSellEntry ? "CHoCH" : bosSellEntry ? "BOS" : "OTE"

// تقييم النجوم
int cStars = 1
if buySignal or sellSignal
    cStars := 2
    if (buySignal and structDir == 1) or (sellSignal and structDir == -1)
        cStars := 3

//═══════════════════════════════════════════════
//  18. وقف خسارة حقيقي من الهيكل (بدون ATR!)
//═══════════════════════════════════════════════
float entrySL = na
if buySignal
    if obBuyEntry
        entrySL := obBot - slBuffer * syminfo.mintick
    else if fvgBuyEntry
        entrySL := fvgBot - slBuffer * syminfo.mintick
    else if sweepBuyEntry
        entrySL := sweepLevel - slBuffer * syminfo.mintick
    else if chochBuyEntry
        entrySL := sl1 - slBuffer * syminfo.mintick
    else if bosBuyEntry
        entrySL := sl1 - slBuffer * syminfo.mintick
    else if oteBuyEntry
        entrySL := (not na(sl1) ? sl1 : oteBot) - slBuffer * syminfo.mintick
if sellSignal
    if obSellEntry
        entrySL := obTop + slBuffer * syminfo.mintick
    else if fvgSellEntry
        entrySL := fvgTop + slBuffer * syminfo.mintick
    else if sweepSellEntry
        entrySL := sweepLevel + slBuffer * syminfo.mintick
    else if chochSellEntry
        entrySL := sh1 + slBuffer * syminfo.mintick
    else if bosSellEntry
        entrySL := sh1 + slBuffer * syminfo.mintick
    else if oteSellEntry
        entrySL := (not na(sh1) ? sh1 : oteTop) + slBuffer * syminfo.mintick

//═══════════════════════════════════════════════
//  19. أهداف ربح حقيقية من الهيكل
//═══════════════════════════════════════════════
var float[] entryTPs = array.new_float()

if buySignal or sellSignal
    float eP = close
    float sL = entrySL
    float riskDist = math.abs(eP - sL)
    array.clear(entryTPs)

    float[] fibs = array.from(0.618, 1.0, 1.272, 1.618, 2.0, 2.618, 3.618, 4.236, 5.0, 6.0)

    float[] structTargets = array.new_float()
    if buySignal
        for i = 0 to array.size(allSH) - 1
            float s = array.get(allSH, i)
            if s > eP + riskDist * 0.3
                array.push(structTargets, s)
        array.sort(structTargets)
    else
        for i = 0 to array.size(allSL) - 1
            float s = array.get(allSL, i)
            if s < eP - riskDist * 0.3
                array.push(structTargets, s)
        array.sort(structTargets, order.descending)

    int structUsed = 0
    int fibIdx = 0
    for i = 0 to numTP - 1
        float tp = eP
        if structUsed < array.size(structTargets)
            tp := array.get(structTargets, structUsed)
            structUsed += 1
        else
            float ext = buySignal ? eP + riskDist * array.get(fibs, math.min(fibIdx, 9)) : eP - riskDist * array.get(fibs, math.min(fibIdx, 9))
            tp := ext
            fibIdx += 1
        array.push(entryTPs, tp)

//═══════════════════════════════════════════════
//  20. HTF
//═══════════════════════════════════════════════
float htfEMA = ta.ema(close, 200)
int htfTr = request.security(syminfo.tickerid, htf, close > htfEMA ? 1 : -1, barmerge.gaps_off, barmerge.lookahead_off)

//═══════════════════════════════════════════════
//  21. دوال بناء النصوص
//═══════════════════════════════════════════════
sigTypeName(string t) =>
    t == "OB" ? "🧱 أوردر بلوك" : t == "FVG" ? "📦 فالو جاب" : t == "Sweep" ? "🌊 تنظيف سيولة" : t == "CHoCH" ? "🔄 تغيير هيكل" : t == "BOS" ? "⚡ كسر هيكل" : "🎯 دخول مثالي"

starStr(int s) => s == 3 ? "⭐⭐⭐" : s == 2 ? "⭐⭐" : "⭐"

buildRiskBlock(float lotSz, float tRisk, float aRisk, float slDist, float maxRR) =>
    float aPct = aRisk > 0.0 and bal > 0.0 ? (aRisk / bal) * 100.0 : 0.0
    string s = "\n💰 إدارة المخاطر\n"
    s += "💵 الرصيد : $" + str.tostring(bal,"#.##") + "\n"
    s += "🎯 خطر مستهدف : $" + str.tostring(math.round(tRisk,2),"#.##") + " (" + str.tostring(riskP,"#.#") + "%)\n"
    s += "📦 حجم اللوت : " + lotStr(lotSz) + "\n"
    s += "💸 خسارة فعلية : $" + str.tostring(math.round(aRisk,2),"#.##") + " (" + str.tostring(math.round(aPct,1),"#.#") + "%)\n"
    s += "📏 مسافة الوقف : " + str.tostring(math.round(slDist,2),"#.##") + "\n"
    s += "📊 R:R الأقصى : 1:" + str.tostring(math.round(maxRR,2),"#.##") + "\n"
    s += "🏦 الأداة : " + inst + "\n"
    if aPct > riskP * 1.5
        s += "\n⚠️ تحذير المخاطر:\n"
        s += "├ مستهدف : " + str.tostring(riskP,"#.#") + "% = $" + str.tostring(math.round(bal * riskP / 100.0,2),"#.##") + "\n"
        s += "├ فعلي : " + str.tostring(math.round(aPct,1),"#.#") + "% = $" + str.tostring(math.round(aRisk,2),"#.##") + "\n"
        s += "└ موصى به: $" + str.tostring(math.round(bal * riskP / 100.0 * 100.0 / aPct,0),"#") + " رصيد\n"
    s

buildTPStatusMain() =>
    string s = ""
    if array.size(tpP) > 0
        for i = 0 to array.size(tpP) - 1
            float p = array.get(tpP, i)
            bool hit = array.get(tpS, i)
            bool cur = (i == mxTPR - 1)
            s += (hit ? "✅" : "⏳") + " TP" + str.tostring(i+1) + ": " + str.tostring(p, format.mintick) + (cur ? " ← الآن" : "") + "\n"
    s

buildTPStatusPyr() =>
    string s = ""
    if array.size(pyTP) > 0
        for i = 0 to array.size(pyTP) - 1
            float p = array.get(pyTP, i)
            bool hit = array.get(pyTS, i)
            s += (hit ? "✅" : "⏳") + " PTP" + str.tostring(i+1) + ": " + str.tostring(p, format.mintick) + "\n"
    s

buildTPStatusRe() =>
    string s = ""
    if array.size(reTP) > 0
        for i = 0 to array.size(reTP) - 1
            float p = array.get(reTP, i)
            bool hit = array.get(reTS, i)
            s += (hit ? "✅" : "⏳") + " RTP" + str.tostring(i+1) + ": " + str.tostring(p, format.mintick) + "\n"
    s

buildEnt() =>
    float sd = math.abs(ep - sl)
    float mxR = sd > 0.0 and not na(mxTP) ? math.abs(mxTP - ep) / sd : 0.0
    float tR = bal * riskP / 100.0
    string m = "╔════════════════════════════════╗\n"
    m += "║ " + (isBuy ? "🟢 إشارة شراء SMC 🚀" : "🔴 إشارة بيع SMC 🔻") + " ║\n"
    m += "╚════════════════════════════════════════════╝\n\n"
    m += "📌 " + syminfo.ticker + " │ " + timeframe.period + " │ " + htfD + "\n"
    m += "⭐ " + starStr(stars) + " | " + sigTypeName(sigType) + "\n\n"
    m += SEP + "\n📊 الصفقة\n" + SEP + "\n"
    m += "🔵 الدخول: " + str.tostring(ep, format.mintick) + "\n"
    m += "🔴 الوقف : " + str.tostring(sl, format.mintick) + " | تأمين تلقائي TP1\n"
    m += buildRiskBlock(sLot, tR, sRisk, sd, mxR)
    m += "\n" + SEP + "\n🎯 الأهداف\n" + SEP + "\n"
    int tpSz = array.size(tpP)
    if tpSz > 0
        for k = 0 to tpSz - 1
            float t = array.get(tpP, k)
            float rr = sd > 0.0 ? math.abs(t - ep) / sd : 0.0
            m += "🎯 TP" + str.tostring(k+1) + ": " + str.tostring(t, format.mintick) + " │ R:R " + str.tostring(math.round(rr,2),"#.##") + "\n"
    m += "\n" + SEP + "\n"
    m += "📈 " + htfD + ": " + (htfTr == 1 ? "صاعد 🐂" : "هابط 🐻") + " | الهيكل: " + (structDir == 1 ? "صاعد" : structDir == -1 ? "هابط" : "عرضي") + "\n"
    m += "🔧 منهجية: SMC / ICT / CRT\n"
    m += SEP + "\n📱 t.me/forexYemeni_Gold"
    m

buildTPA(int n, bool jump) =>
    float hp = array.size(tpP) > 0 ? array.get(tpP, math.max(0, n-1)) : ep
    float pp = math.abs(hp - ep)
    float pd = pnlD(sLot, pp)
    string m = "╔════════════════════════════════╗\n"
    if n == numTP
        m += "║ 🏆 إغلاق كامل بالربح! ║\n"
    else if jump
        m += "║ 🚀 قفزة سعرية! ║\n"
    else
        m += "║ ✅ تحقق الهدف " + str.tostring(n) + " ║\n"
    m += "╚════════════════════════════════════════════╝\n\n"
    m += "📌 " + syminfo.ticker + " | SMC\n"
    if jump
        m += "⚡ الأهداف " + str.tostring(laTP2+1) + " ← " + str.tostring(n) + " معاً!\n"
    m += "🎯 " + str.tostring(hp, format.mintick) + " │ +" + str.tostring(math.round(pp,2),"#.##") + " نقطة\n"
    m += "💰 ربح تقريبي: +$" + str.tostring(math.round(pd,2),"#.##") + "\n\n"
    m += SEP + "\n" + buildTPStatusMain() + SEP + "\n"
    if n == numTP
        m += "🎊 جميع الأهداف محققة!\n"
    else if n >= 1
        m += "🛡️ التأمين مفعّل\n"
    m += SEP + "\n📱 t.me/forexYemeni_Gold"
    m

buildSLA() =>
    float lp = math.abs(ep - iSL)
    float ld = pnlD(sLot, lp)
    string m = ""
    if mxTPR == 0
        m := "╔════════════════════════════════╗\n"
        m += "║ ❌ ضرب الوقف — خسارة كاملة ║\n"
        m += "╚════════════════════════════════╝\n\n"
        m += "📌 " + syminfo.ticker + " | SMC\n"
        m += "❌ الوقف: " + str.tostring(sl, format.mintick) + " | -" + str.tostring(math.round(lp,2),"#.##") + " نقطة\n"
        m += "💰 الخسارة: $" + str.tostring(math.round(ld,2),"#.##") + "\n\n"
        m += SEP + "\n" + buildTPStatusMain() + SEP + "\n"
        if useReentry
            bool ok = (isBuy and htfTr == 1 and structDir == 1) or (not isBuy and htfTr == -1 and structDir == -1)
            if ok
                m += "♻️ جاري البحث عن صفقة تعويض...\n"
    else if beSent and mxTPR <= 1
        m := "╔════════════════════════════════╗\n"
        m += "║ ⚖️ ضرب الوقف عند الدخول ║\n"
        m += "╚════════════════════════════════╝\n\n"
        m += "📌 " + syminfo.ticker + " | SMC\n"
        m += "⚖️ تم تحقيق هدف ثم عاد السعر\n"
        m += "🛡️ تم الخروج عند نقطة الدخول (بدون خسارة)\n"
        m += "✅ " + str.tostring(mxTPR) + "/" + str.tostring(numTP) + " أهداف\n\n"
        m += SEP + "\n" + buildTPStatusMain() + SEP + "\n"
    else
        string ct = sl == iSL ? "⚠️ الوقف الأساسي" : useTrail ? "🔒 الوقف المتتبع" : "🛡️ التأمين"
        m := "╔════════════════════════════════╗\n"
        m += "║ " + ct + " ║\n"
        m += "╚════════════════════════════════╝\n\n"
        m += "📌 " + syminfo.ticker + " | SMC\n\n"
        m += SEP + "\n" + buildTPStatusMain() + SEP + "\n"
        m += "✅ " + str.tostring(mxTPR) + "/" + str.tostring(numTP) + " أهداف\n"
        m += "💰 ربح جزئي ✅\n"
    m += SEP + "\n📱 t.me/forexYemeni_Gold"
    m

buildBE() =>
    string m = "╔════════════════════════════════╗\n"
    m += "║ 🛡️ تأمين تلقائي ← الدخول ║\n"
    m += "╚════════════════════════════════════════════╝\n\n"
    m += "📌 " + syminfo.ticker + " | SMC\n"
    m += "🛡️ تم سحب الوقف لنقطة الدخول تلقائياً\n"
    m += "🔵 الدخول: " + str.tostring(ep, format.mintick) + "\n"
    m += "✅ تم تحقيق " + str.tostring(mxTPR) + " أهداف\n"
    m += "💰 الصفقة الآن محمية بدون خسارة\n\n"
    m += SEP + "\n" + buildTPStatusMain() + SEP + "\n"
    m += "📱 t.me/forexYemeni_Gold"
    m

buildPyrEnt() =>
    float sd = math.abs(pyE - pySL)
    float mxT = array.size(pyTP) > 0 ? array.get(pyTP, array.size(pyTP)-1) : pyE
    float mxR = sd > 0.0 ? math.abs(mxT - pyE) / sd : 0.0
    float tR = bal * riskP / 100.0
    string m = "╔════════════════════════════════╗\n"
    m += "║ 🔥 تعزيز " + (isBuy ? "شراء 🚀" : "بيع 🔻") + " ║\n"
    m += "╚════════════════════════════════════════════╝\n\n"
    m += "📌 " + syminfo.ticker + " | " + str.tostring(mxTPR) + " أهداف محققة\n\n"
    m += SEP + "\n📊 التعزيز\n" + SEP + "\n"
    m += "🔵 الدخول: " + str.tostring(pyE, format.mintick) + "\n"
    m += "🔴 الوقف : " + str.tostring(pySL, format.mintick) + "\n"
    m += buildRiskBlock(pyLot, tR, pnlD(pyLot, sd), sd, mxR)
    m += "\n" + SEP + "\n🎯 أهداف التعزيز\n" + SEP + "\n"
    int pySz = array.size(pyTP)
    if pySz > 0
        for k = 0 to pySz - 1
            float t = array.get(pyTP, k)
            float rr = sd > 0.0 ? math.abs(t - pyE) / sd : 0.0
            m += "🔥 TP" + str.tostring(k+1) + ": " + str.tostring(t, format.mintick) + " │ R:R " + str.tostring(math.round(rr,2),"#.##") + "\n"
    m += SEP + "\n📱 t.me/forexYemeni_Gold"
    m

buildPyrTPA(int n) =>
    float hp = array.size(pyTP) > 0 ? array.get(pyTP, math.max(0, n-1)) : pyE
    float pp = math.abs(hp - pyE)
    float pd = pnlD(pyLot, pp)
    string m = "╔════════════════════════════════╗\n"
    m += n == pyrTP ? "║ 🏆 تعزيز كامل بالربح! 🎊 ║\n" : "║ ✅ هدف التعزيز " + str.tostring(n) + " ║\n"
    m += "╚════════════════════════════════════════════╝\n\n"
    m += "📌 " + syminfo.ticker + " | 🔥 التعزيز\n"
    m += "🎯 " + str.tostring(hp, format.mintick) + " │ +" + str.tostring(math.round(pp,2),"#.##") + " نقطة\n"
    m += "💰 ربح تقريبي: +$" + str.tostring(math.round(pd,2),"#.##") + "\n\n"
    m += SEP + "\n" + buildTPStatusPyr() + SEP + "\n"
    m += "📱 t.me/forexYemeni_Gold"
    m

buildPyrSLA() =>
    float lp = math.abs(pyE - pySL)
    float ld = pnlD(pyLot, lp)
    string m = "╔════════════════════════════════╗\n"
    m += "║ ❌ ضرب وقف التعزيز ║\n"
    m += "╚════════════════════════════════════════════╝\n\n"
    m += "📌 " + syminfo.ticker + " | 🔥 التعزيز\n"
    m += "❌ الوقف: " + str.tostring(pySL, format.mintick) + " | -" + str.tostring(math.round(lp,2),"#.##") + " نقطة\n"
    m += "💰 الخسارة: $" + str.tostring(math.round(ld,2),"#.##") + "\n\n"
    m += SEP + "\n" + buildTPStatusPyr() + SEP + "\n"
    if pyrR >= 1
        m += "💰 ربح جزئي ✅\n"
    m += "📱 t.me/forexYemeni_Gold"
    m

buildReEnt() =>
    float sd = math.abs(reE - reSL)
    float mxT = array.size(reTP) > 0 ? array.get(reTP, array.size(reTP)-1) : reE
    float mxR = sd > 0.0 ? math.abs(mxT - reE) / sd : 0.0
    float tR = bal * riskP / 100.0
    string m = "╔════════════════════════════════╗\n"
    m += "║ ♻️ صفقة تعويض " + (isBuyRe ? "شراء 🚀" : "بيع 🔻") + " ║\n"
    m += "╚════════════════════════════════════════════╝\n\n"
    m += "📌 " + syminfo.ticker + " | الاتجاه يدعم الدخول!\n\n"
    m += SEP + "\n📊 التعويض\n" + SEP + "\n"
    m += "🔵 الدخول: " + str.tostring(reE, format.mintick) + "\n"
    m += "🔴 الوقف : " + str.tostring(reSL, format.mintick) + "\n"
    m += buildRiskBlock(reLot, tR, pnlD(reLot, sd), sd, mxR)
    m += "\n" + SEP + "\n🎯 أهداف التعويض\n" + SEP + "\n"
    int reSz = array.size(reTP)
    if reSz > 0
        for k = 0 to reSz - 1
            float t = array.get(reTP, k)
            float rr = sd > 0.0 ? math.abs(t - reE) / sd : 0.0
            m += "♻️ TP" + str.tostring(k+1) + ": " + str.tostring(t, format.mintick) + " │ R:R " + str.tostring(math.round(rr,2),"#.##") + "\n"
    m += SEP + "\n📱 t.me/forexYemeni_Gold"
    m

buildReTPA(int n) =>
    float hp = array.size(reTP) > 0 ? array.get(reTP, math.max(0, n-1)) : reE
    float pp = math.abs(hp - reE)
    float pd = pnlD(reLot, pp)
    string m = "╔════════════════════════════════╗\n"
    m += n == reTPn ? "║ 🏆 تعويض كامل بالربح! ♻️ 🎊 ║\n" : "║ ✅ هدف التعويض " + str.tostring(n) + " ║\n"
    m += "╚════════════════════════════════════════════╝\n\n"
    m += "📌 " + syminfo.ticker + " | ♻️ التعويض\n"
    m += "🎯 " + str.tostring(hp, format.mintick) + " │ +" + str.tostring(math.round(pp,2),"#.##") + " نقطة\n"
    m += "💰 ربح تقريبي: +$" + str.tostring(math.round(pd,2),"#.##") + "\n\n"
    m += SEP + "\n" + buildTPStatusRe() + SEP + "\n"
    m += "📱 t.me/forexYemeni_Gold"
    m

buildReSLA() =>
    float lp = math.abs(reE - reSL)
    float ld = pnlD(reLot, lp)
    string m = "╔════════════════════════════════╗\n"
    m += "║ ❌ ضرب وقف التعويض ║\n"
    m += "╚════════════════════════════════════════════╝\n\n"
    m += "📌 " + syminfo.ticker + " | ♻️ التعويض\n"
    m += "❌ الوقف: " + str.tostring(reSL, format.mintick) + " | -" + str.tostring(math.round(lp,2),"#.##") + " نقطة\n"
    m += "💰 الخسارة: $" + str.tostring(math.round(ld,2),"#.##") + "\n\n"
    m += SEP + "\n" + buildTPStatusRe() + SEP + "\n"
    if reR >= 1
        m += "💰 ربح جزئي ✅\n"
    m += "📱 t.me/forexYemeni_Gold"
    m

//═══════════════════════════════════════════════
//  22. حذف الرسومات
//═══════════════════════════════════════════════
clrM() =>
    if not na(eL)
        line.delete(eL)
    if not na(slL)
        line.delete(slL)
    if not na(eLb)
        label.delete(eLb)
    if not na(slLb)
        label.delete(slLb)
    int szL = array.size(tpL)
    if szL > 0
        for j = 0 to szL - 1
            line.delete(array.get(tpL, j))
    int szLb = array.size(tpLb)
    if szLb > 0
        for j = 0 to szLb - 1
            label.delete(array.get(tpLb, j))

clrP() =>
    if not na(pyEL)
        line.delete(pyEL)
    if not na(pySLL)
        line.delete(pySLL)
    if not na(pyELb)
        label.delete(pyELb)
    if not na(pySLb)
        label.delete(pySLb)
    int szL = array.size(pyTL)
    if szL > 0
        for j = 0 to szL - 1
            line.delete(array.get(pyTL, j))
    int szLb = array.size(pyTLb)
    if szLb > 0
        for j = 0 to szLb - 1
            label.delete(array.get(pyTLb, j))

clrR() =>
    if not na(reEL)
        line.delete(reEL)
    if not na(reSLL)
        line.delete(reSLL)
    if not na(reELb)
        label.delete(reELb)
    if not na(reSLb)
        label.delete(reSLb)
    int szL = array.size(reTL)
    if szL > 0
        for j = 0 to szL - 1
            line.delete(array.get(reTL, j))
    int szLb = array.size(reTLb)
    if szLb > 0
        for j = 0 to szLb - 1
            label.delete(array.get(reTLb, j))

clrAll() =>
    clrM()
    clrP()
    clrR()

wrC(float pct) => pct >= 60.0 ? cG : pct >= 40.0 ? cAu : cR

//═══════════════════════════════════════════════
//  23. مراقبة الصفقة
//═══════════════════════════════════════════════
if inT
    int tpSzM = array.size(tpP)
    if tpSzM > 0
        bool hitBE = false
        for i = 0 to tpSzM - 1
            if not array.get(tpS, i)
                float t = array.get(tpP, i)
                if (isBuy and high >= t) or (not isBuy and low <= t)
                    array.set(tpS, i, true)
                    mxTPR := math.max(mxTPR, i + 1)
                    label.set_text(array.get(tpLb, i), "✅" + str.tostring(i+1))
                    if i == 0 and not beSent
                        hitBE := true
                else
                    break
            else
                break

        if hitBE and inT
            float bv = beBufPx()
            float nBE = isBuy ? ep + bv : ep - bv
            if (isBuy and sl < nBE) or (not isBuy and sl > nBE)
                sl := nBE
                beSent := true
                line.set_y1(slL, sl)
                line.set_y2(slL, sl)
                label.set_y(slLb, sl)
                label.set_text(slLb, "🛡️" + str.tostring(sl, format.mintick))
                label.set_color(slLb, cGr)
                line.set_color(slL, cGr)
                alert(buildBE(), alert.freq_once_per_bar_close)

        if mxTPR > laTP2 and inT
            bool isJump = (mxTPR - laTP2) > 1
            alert(buildTPA(mxTPR, isJump), alert.freq_once_per_bar_close)
            if mxTPR == numTP
                if not tradeCnt
                    winT += 1
                    totT += 1
                    tradeCnt := true
                    array.push(tCTime, entryTime)
                    array.push(tCWin, 1)
                inT := false
                lastSig := 0
                inPy := false
                pyrSent := false
                beSent := false
                clrAll()
                lastExit := bar_index
            laTP2 := mxTPR

        if useTrail and mxTPR > 1 and inT and array.size(tpP) > 0
            float nSL = array.get(tpP, mxTPR - 2)
            if (isBuy and nSL > sl) or (not isBuy and nSL < sl)
                sl := nSL
                line.set_y1(slL, sl)
                line.set_y2(slL, sl)
                label.set_y(slLb, sl)
                label.set_text(slLb, "🔒" + str.tostring(sl, format.mintick))
                label.set_color(slLb, cGr)
                line.set_color(slL, cGr)

    bool slH = (isBuy and low <= sl) or (not isBuy and high >= sl)
    if slH and not slSent and inT
        alert(buildSLA(), alert.freq_once_per_bar_close)
        slSent := true
        if not tradeCnt
            if mxTPR >= 1
                winT += 1
            else
                lossT += 1
            totT += 1
            tradeCnt := true
            array.push(tCTime, entryTime)
            array.push(tCWin, mxTPR >= 1 ? 1 : 0)
        if useReentry and mxTPR == 0
            pendRe := true
            isBuyRe := isBuy
        inT := false
        lastSig := 0
        inPy := false
        pyrSent := false
        beSent := false
        clrAll()
        lastExit := bar_index

//═══════════════════════════════════════════════
//  24. التعزيز
//═══════════════════════════════════════════════
if inT and not inPy and not inRe and usePyr and mxTPR >= pyrTP and not pyrSent
    pyrSent := true
    pyrR := 0
    pyrLA := 0
    inPy := true
    pyrSLAS := false
    pyE := close

    float pSD = math.max(math.abs(pyE - sl), syminfo.mintick)
    pySL := isBuy ? pyE - pSD : pyE + pSD

    float pRisk = bal * riskP / 100.0
    pyLot := calcLot(pRisk, math.abs(pyE - pySL))

    pyEL := line.new(bar_index, pyE, bar_index+1, pyE, extend=extend.right, color=cP, width=2)
    pyELb := label.new(bar_index, pyE, "🔥" + str.tostring(pyE, format.mintick), style=label.style_label_left, color=cP, textcolor=color.white, size=size.small)
    pySLL := line.new(bar_index, pySL, bar_index+1, pySL, extend=extend.right, color=cR, width=2, style=line.style_dashed)
    pySLb := label.new(bar_index, pySL, "🔴" + str.tostring(pySL, format.mintick), style=label.style_label_left, color=cR, textcolor=color.white, size=size.small)

    array.clear(pyTP), array.clear(pyTL), array.clear(pyTLb), array.clear(pyTS)

    float pySD = math.abs(pyE - pySL)
    for j = 0 to pyrTP - 1
        float pt = isBuy ? pyE + pySD * pyrRR * (j+1) : pyE - pySD * pyrRR * (j+1)
        color tc = array.get(tpC, math.min(j, 9))
        line tl = line.new(bar_index, pt, bar_index+1, pt, extend=extend.right, color=tc, width=1)
        label tlb = label.new(bar_index, pt, "🔥" + str.tostring(j+1), style=label.style_label_left, color=tc, textcolor=color.white, size=size.small)
        array.push(pyTL, tl), array.push(pyTLb, tlb), array.push(pyTP, pt), array.push(pyTS, false)

    alert(buildPyrEnt(), alert.freq_once_per_bar_close)

if inPy
    int pySzT = array.size(pyTP)
    if pySzT > 0
        for i = 0 to pySzT - 1
            if not array.get(pyTS, i)
                float t = array.get(pyTP, i)
                if (isBuy and high >= t) or (not isBuy and low <= t)
                    array.set(pyTS, i, true)
                    pyrR := math.max(pyrR, i + 1)
                    label.set_text(array.get(pyTLb, i), "✅" + str.tostring(i+1))
                else
                    break
            else
                break

        if pyrR > pyrLA and inPy
            alert(buildPyrTPA(pyrR), alert.freq_once_per_bar_close)
            if pyrR == pyrTP
                inPy := false
                clrP()
            pyrLA := pyrR

    bool pySLH = (isBuy and low <= pySL) or (not isBuy and high >= pySL)
    if pySLH and not pyrSLAS and inPy
        alert(buildPyrSLA(), alert.freq_once_per_bar_close)
        pyrSLAS := true
        inPy := false
        clrP()

//═══════════════════════════════════════════════
//  25. التعويض
//═══════════════════════════════════════════════
if pendRe and bar_index > lastExit + 5 and not inT and not inRe
    bool ok = (isBuyRe and htfTr == 1 and structDir == 1) or (not isBuyRe and htfTr == -1 and structDir == -1)
    if ok
        float reRisk = math.abs(entrySL - close) * reMult
        inRe := true
        pendRe := false
        reCnt := false
        isBuyRe := isBuyRe
        reE := close
        reSL := isBuyRe ? close - reRisk : close + reRisk
        reLot := calcLot(bal * riskP / 100.0, math.abs(reE - reSL))
        reR := 0
        reLA := 0
        reSLS := false

        reEL := line.new(bar_index, reE, bar_index+1, reE, extend=extend.right, color=cO, width=2)
        reELb := label.new(bar_index, reE, "♻️" + str.tostring(reE, format.mintick), style=label.style_label_left, color=cO, textcolor=color.white, size=size.small)
        reSLL := line.new(bar_index, reSL, bar_index+1, reSL, extend=extend.right, color=cR, width=2, style=line.style_dashed)
        reSLb := label.new(bar_index, reSL, "🔴" + str.tostring(reSL, format.mintick), style=label.style_label_left, color=cR, textcolor=color.white, size=size.small)

        array.clear(reTP), array.clear(reTL), array.clear(reTLb), array.clear(reTS)
        float reSD = math.abs(reE - reSL)
        for j = 0 to reTPn - 1
            float pt = isBuyRe ? reE + reSD * 2.0 * (j+1) : reE - reSD * 2.0 * (j+1)
            color tc = array.get(tpC, math.min(j, 9))
            line tl = line.new(bar_index, pt, bar_index+1, pt, extend=extend.right, color=tc, width=1)
            label tlb = label.new(bar_index, pt, "♻️" + str.tostring(j+1), style=label.style_label_left, color=tc, textcolor=color.white, size=size.small)
            array.push(reTL, tl), array.push(reTLb, tlb), array.push(reTP, pt), array.push(reTS, false)

        alert(buildReEnt(), alert.freq_once_per_bar_close)
    else
        pendRe := false

if inRe
    int reSzT = array.size(reTP)
    if reSzT > 0
        for i = 0 to reSzT - 1
            if not array.get(reTS, i)
                float t = array.get(reTP, i)
                if (isBuyRe and high >= t) or (not isBuyRe and low <= t)
                    array.set(reTS, i, true)
                    reR := math.max(reR, i + 1)
                    label.set_text(array.get(reTLb, i), "✅" + str.tostring(i+1))
                else
                    break
            else
                break

        if reR > reLA and inRe
            alert(buildReTPA(reR), alert.freq_once_per_bar_close)
            if reR == reTPn
                if reR >= 1
                    reWin += 1
                else
                    reLoss += 1
                inRe := false
                clrR()
            reLA := reR

    bool reSLH = (isBuyRe and low <= reSL) or (not isBuyRe and high >= reSL)
    if reSLH and not reSLS and inRe
        alert(buildReSLA(), alert.freq_once_per_bar_close)
        reSLS := true
        reLoss += 1
        inRe := false
        clrR()

//═══════════════════════════════════════════════
//  26. تنفيذ الدخول (بدون ATR!)
//═══════════════════════════════════════════════
if not inT and not pendRe and not inRe and barstate.isconfirmed and not inPy
    float tRisk = bal * riskP / 100.0
    int tpSz = array.size(entryTPs)

    if buySignal and cStars >= minStars and not na(entrySL) and tpSz >= numTP and not slSent
        isBuy := true
        inT := true
        ep := close
        sl := entrySL
        iSL := sl
        sLot := calcLot(tRisk, math.abs(ep - sl))
        sRisk := pnlD(sLot, math.abs(ep - sl))
        sigType := cSigType
        stars := cStars
        entryTime := time
        mxTPR := 0
        laTP2 := 0
        slSent := false
        pyrSent := false
        beSent := false
        tradeCnt := false
        lastSig := 1

        eL := line.new(bar_index, ep, bar_index+1, ep, extend=extend.right, color=cBl, width=2)
        slL := line.new(bar_index, sl, bar_index+1, sl, extend=extend.right, color=cR, width=2, style=line.style_dashed)
        eLb := label.new(bar_index, ep, "🔵 دخول " + str.tostring(ep, format.mintick), style=label.style_label_left, color=cBl, textcolor=color.white, size=size.small)
        slLb := label.new(bar_index, sl, "🔴 وقف " + str.tostring(sl, format.mintick), style=label.style_label_left, color=cR, textcolor=color.white, size=size.small)

        array.clear(tpP), array.clear(tpL), array.clear(tpLb), array.clear(tpS)
        for i = 0 to tpSz - 1
            float t = array.get(entryTPs, i)
            color tc = array.get(tpC, math.min(i, 9))
            line tl = line.new(bar_index, t, bar_index+1, t, extend=extend.right, color=tc, width=1)
            label tlb = label.new(bar_index, t, "🎯" + str.tostring(i+1), style=label.style_label_left, color=tc, textcolor=color.white, size=size.small)
            array.push(tpL, tl), array.push(tpLb, tlb), array.push(tpP, t), array.push(tpS, false)

        mxTP := tpSz > 0 ? array.get(tpP, tpSz - 1) : ep

        alert(buildEnt(), alert.freq_once_per_bar_close)

    if sellSignal and cStars >= minStars and not na(entrySL) and tpSz >= numTP and not slSent
        isBuy := false
        inT := true
        ep := close
        sl := entrySL
        iSL := sl
        sLot := calcLot(tRisk, math.abs(ep - sl))
        sRisk := pnlD(sLot, math.abs(ep - sl))
        sigType := cSigType
        stars := cStars
        entryTime := time
        mxTPR := 0
        laTP2 := 0
        slSent := false
        pyrSent := false
        beSent := false
        tradeCnt := false
        lastSig := -1

        eL := line.new(bar_index, ep, bar_index+1, ep, extend=extend.right, color=cP, width=2)
        slL := line.new(bar_index, sl, bar_index+1, sl, extend=extend.right, color=cR, width=2, style=line.style_dashed)
        eLb := label.new(bar_index, ep, "🔴 دخول " + str.tostring(ep, format.mintick), style=label.style_label_left, color=cP, textcolor=color.white, size=size.small)
        slLb := label.new(bar_index, sl, "🔴 وقف " + str.tostring(sl, format.mintick), style=label.style_label_left, color=cR, textcolor=color.white, size=size.small)

        array.clear(tpP), array.clear(tpL), array.clear(tpLb), array.clear(tpS)
        for i = 0 to tpSz - 1
            float t = array.get(entryTPs, i)
            color tc = array.get(tpC, math.min(i, 9))
            line tl = line.new(bar_index, t, bar_index+1, t, extend=extend.right, color=tc, width=1)
            label tlb = label.new(bar_index, t, "🎯" + str.tostring(i+1), style=label.style_label_left, color=tc, textcolor=color.white, size=size.small)
            array.push(tpL, tl), array.push(tpLb, tlb), array.push(tpP, t), array.push(tpS, false)

        mxTP := tpSz > 0 ? array.get(tpP, tpSz - 1) : ep

        alert(buildEnt(), alert.freq_once_per_bar_close)

//═══════════════════════════════════════════════
//  27. عرض السوينج
//═══════════════════════════════════════════════
if showSwing
    if not na(ph)
        label.new(bar_index - swingLen, ph, "q", color=cR, textcolor=color.white, style=label.style_label_down, size=size.tiny)
    if not na(pl)
        label.new(bar_index - swingLen, pl, "s", color=cG, textcolor=color.white, style=label.style_label_up, size=size.tiny)

//═══════════════════════════════════════════════
//  28. عرض BOS / CHoCH
//═══════════════════════════════════════════════
if showBOS and barstate.isconfirmed
    if bosBull
        label.new(bar_index, high, "BOS↑", color=cG, textcolor=color.white, style=label.style_label_down, size=size.small)
    if bosBear
        label.new(bar_index, low, "BOS↓", color=cR, textcolor=color.white, style=label.style_label_up, size=size.small)
    if chochBull
        label.new(bar_index, high, "CHoCH↑", color=cCy, textcolor=color.white, style=label.style_label_down, size=size.small)
    if chochBear
        label.new(bar_index, low, "CHoCH↓", color=cAu, textcolor=color.white, style=label.style_label_up, size=size.small)

//═══════════════════════════════════════════════
//  29. خلفية الصفقة
//═══════════════════════════════════════════════
bgcolor(inT and isBuy and showTradeBG ? color.new(#00E676,92) : inT and not isBuy and showTradeBG ? color.new(#FF5252,92) : na)

//═══════════════════════════════════════════════
//  30. جدول الإحصائيات
//═══════════════════════════════════════════════
var table statTbl = table.new(position.top_right, 2, 9, bgcolor=color.new(#1E222D,10), border_width=1, border_color=color.new(color.gray,70))

if barstate.islast
    float wr = totT > 0 ? (winT / totT) * 100.0 : 0.0
    int totalTrades = totT + reWin + reLoss
    int totalWins = winT + reWin
    int totalLosses = lossT + reLoss
    float totalWR = totalTrades > 0 ? (totalWins / totalTrades) * 100.0 : 0.0

    table.cell(statTbl, 0, 0, "📊 FYP-SMC v4.0", text_color=color.white, text_size=size.small)
    table.cell(statTbl, 1, 0, "SMC/ICT/CRT", text_color=cCy, text_size=size.small)

    table.cell(statTbl, 0, 1, "📈 نسبة النجاح", text_color=color.white, text_size=size.tiny)
    table.cell(statTbl, 1, 1, str.tostring(math.round(totalWR,1),"#.##") + "%", text_color=wrC(totalWR), text_size=size.tiny)

    table.cell(statTbl, 0, 2, "📊 إجمالي الصفقات", text_color=color.white, text_size=size.tiny)
    table.cell(statTbl, 1, 2, str.tostring(totalTrades), text_color=cAu, text_size=size.tiny)

    table.cell(statTbl, 0, 3, "✅ فوز", text_color=color.white, text_size=size.tiny)
    table.cell(statTbl, 1, 3, str.tostring(totalWins), text_color=cG, text_size=size.tiny)

    table.cell(statTbl, 0, 4, "❌ خسارة", text_color=color.white, text_size=size.tiny)
    table.cell(statTbl, 1, 4, str.tostring(totalLosses), text_color=cR, text_size=size.tiny)

    table.cell(statTbl, 0, 5, "📐 الهيكل", text_color=color.white, text_size=size.tiny)
    table.cell(statTbl, 1, 5, structDir == 1 ? "صاعد 🐂" : structDir == -1 ? "هابط 🐻" : "عرضي ➡️", text_color=structDir == 1 ? cG : structDir == -1 ? cR : cGr, text_size=size.tiny)

    table.cell(statTbl, 0, 6, "📈 HTF", text_color=color.white, text_size=size.tiny)
    table.cell(statTbl, 1, 6, htfTr == 1 ? "صاعد" : "هابط", text_color=htfTr == 1 ? cG : cR, text_size=size.tiny)

    table.cell(statTbl, 0, 7, "🏦 الأداة", text_color=color.white, text_size=size.tiny)
    table.cell(statTbl, 1, 7, instShort, text_color=cCy, text_size=size.tiny)

    table.cell(statTbl, 0, 8, "⏱️ الفريم", text_color=color.white, text_size=size.tiny)
    table.cell(statTbl, 1, 8, timeframe.period, text_color=cAu, text_size=size.tiny)

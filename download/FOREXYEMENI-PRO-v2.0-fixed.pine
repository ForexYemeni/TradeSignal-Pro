//@version=5
indicator("FOREXYEMENI-PRO-v2.0", shorttitle="FOREXYEMENI-PRO-v2.0", overlay=true,
    max_lines_count=500, max_labels_count=500, max_boxes_count=100)

//══════════════════════════════════════════════════════════════════════════════
// 0. رسالة الترحيب
//══════════════════════════════════════════════════════════════════════════════
var table welcomeTable = table.new(position.top_center, 1, 3, border_width=1,
    border_color=color.new(color.gray, 80), frame_color=color.new(color.gray, 80), frame_width=1)

if barstate.isfirst
    table.cell(welcomeTable, 0, 0, "مرحباً بكم في مؤشر FOREXYEMENI-PRO", text_color=color.new(#FFC107,
        0), text_size=size.normal, bgcolor=color.new(#1E222D, 10))
    table.cell(welcomeTable, 0, 1, "قناتنا على التليجرام 👇", text_color=color.white,
        text_size=size.small, bgcolor=color.new(#1E222D, 10))
    table.cell(welcomeTable, 0, 2, "https://t.me/forexYemeni_Gold", text_color=color.new(#00BCD4, 0),
        text_size=size.small, bgcolor=color.new(#1E222D, 10))

//══════════════════════════════════════════════════════════════════════════════
// 1. دالة الفريم الأكبر التلقائي
//══════════════════════════════════════════════════════════════════════════════
getHigherTimeframe() =>
    string result = ""
    if timeframe.isseconds
        result := "5"
    else if timeframe.isminutes
        if timeframe.multiplier <= 1
            result := "15"
        else if timeframe.multiplier <= 3
            result := "30"
        else if timeframe.multiplier <= 5
            result := "60"
        else if timeframe.multiplier <= 15
            result := "240"
        else if timeframe.multiplier <= 30
            result := "240"
        else if timeframe.multiplier <= 60
            result := "D"
        else if timeframe.multiplier <= 240
            result := "D"
        else
            result := "W"
    else if timeframe.isdaily
        result := "W"
    else if timeframe.isweekly
        result := "M"
    else if timeframe.ismonthly
        result := "12M"
    else
        result := "D"
    result

string autoHTF = getHigherTimeframe()

getHTFDisplayName(string tf) =>
    tf == "1" ? "1د" : tf == "3" ? "3د" : tf == "5" ? "5د" : tf == "15" ? "15د" : tf == "30" ? "30د" :
        tf == "60" ? "1س" : tf == "240" ? "4س" : tf == "D" ? "يومي" : tf == "W" ? "أسبوعي" : tf == "M" ?
            "شهري" : tf == "12M" ? "سنوي" : tf

string htfDisplayName = getHTFDisplayName(autoHTF)

//══════════════════════════════════════════════════════════════════════════════
// 2. الإعدادات الأساسية
//══════════════════════════════════════════════════════════════════════════════
grpBase = "⚙️ إعدادات الإشارة"
length = input.int(22, "طول ATR", group=grpBase)
mult = input.float(2.0, "معامل ATR", step=0.1, group=grpBase)
useClose = input.bool(true, "استخدام الإغلاق للقمم والقيعان", group=grpBase)

grpInst = "🏛️ الفلاتر المؤسساتية"
useAutoHTF = input.bool(true, "فريم أكبر تلقائي", group=grpInst)
manualHTF = input.timeframe("60", "الفريم الأكبر (يدوي)", group=grpInst)
smcLen = input.int(3, "حساسية هيكل السوق", minval=1, group=grpInst)
minStars = input.int(1, "الحد الأدنى للنجوم", minval=1, maxval=3, group=grpInst)
showSMC = input.bool(true, "إظهار FVG", group=grpInst)
showOB = input.bool(true, "إظهار Order Blocks", group=grpInst)
showSR = input.bool(true, "إظهار الدعوم والمقاومات", group=grpInst)

string htf = useAutoHTF ? autoHTF : manualHTF
string htfDisplay = useAutoHTF ? htfDisplayName : getHTFDisplayName(manualHTF)

grpTgt = "🎯 الأهداف والوقف"
numTargets = input.int(10, "عدد الأهداف", minval=1, maxval=10, group=grpTgt)
tpMode = input.string("فيبوناتشي (Fib)", "نوع الأهداف", options=["ATR","مضاعفات الوقف (RR)","
    فيبوناتشي (Fib)","قمم وقيعان (Swings)"], group=grpTgt)
slMode = input.string("ATR", "نوع الوقف", options=["ATR","Swing (قمم وقيعان)","
    FVG (فجوات السيولة)"], group=grpTgt)
slMult = input.float(1.0, "مضاعف الوقف", step=0.1, group=grpTgt)
useBreakeven = input.bool(false, "تأمين الصفقة", group=grpTgt)
beTrigger = input.int(1, "تفعيل التأمين بعد الهدف:", minval=1, maxval=5, group=grpTgt)
beBuffer = input.float(0.5, "هامش التأمين", step=0.1, group=grpTgt)
useTrailing = input.bool(false, "الوقف التتبعي", group=grpTgt)

grpExtra = "⚡ التعويض والتعزيز"
useReentry = input.bool(false, "تفعيل صفقة التعويض", group=grpExtra)
reentryMult = input.float(1.5, "مضاعف وقف التعويض", step=0.1, group=grpExtra)
reentryRR = input.float(2.0, "نسبة R:R للتعويض", step=0.1, group=grpExtra)
reentryTargets = input.int(5, "عدد أهداف التعويض", minval=1, maxval=10, group=grpExtra)
usePyr = input.bool(true, "تفعيل صفقات التعزيز", group=grpExtra)
pyrTargets = input.int(3, "أهداف التعزيز", minval=1, maxval=5, group=grpExtra)
pyrSLMode = input.string("آخر هدف محقق", "وقف التعزيز", options=["آخر هدف محقق","ATR من الدخول","
    الدخول الأصلي"], group=grpExtra)
pyrRR = input.float(1.5, "R:R أهداف التعزيز", step=0.1, group=grpExtra)

//══════════════════════════════════════════════════════════════════════════════
// 3. إدارة المخاطر — الإعدادات الوحيدة المطلوبة
//══════════════════════════════════════════════════════════════════════════════
grpRisk = "💰 إدارة المخاطر"
accBalance = input.float(1000.0, "💵 رصيد الحساب ($)", step=100, minval=1, group=grpRisk)
riskPct = input.float(1.0, "⚠️ نسبة المخاطرة (%)", step=0.1, minval=0.1, maxval=100, group=grpRisk)

grpStat = "📊 الإحصائيات"
statPeriod = input.string("كل البيانات", "الفترة", options=["آخر 24 ساعة","آخر 7 أيام","
    آخر 30 يوم","كل البيانات"], group=grpStat)

//══════════════════════════════════════════════════════════════════════════════
// 4. الكشف التلقائي عن الأداة — لا حاجة لإعداد يدوي
//══════════════════════════════════════════════════════════════════════════════
getAutoInstrument() =>
    string t = syminfo.ticker
    string inst = "فوركس (5 أرقام)"
    // الذهب
    if str.contains(t, "XAU") or str.contains(t, "GOLD")
        inst := "الذهب (XAUUSD)"
    // الفضة
    else if str.contains(t, "XAG") or str.contains(t, "SILVER")
        inst := "الفضة (XAGUSD)"
    // العملات الرقمية
    else if str.contains(t, "BTC") or str.contains(t, "ETH") or str.contains(t,
        "BNB") or str.contains(t, "SOL") or str.contains(t, "XRP") or str.contains(t, "ADA") or
            str.contains(t, "DOGE") or str.contains(t, "DOT") or str.contains(t, "USDT")
        inst := "عملات رقمية"
    // المؤشرات
    else if str.contains(t, "NAS") or str.contains(t, "NDX") or str.contains(t,
        "US30") or str.contains(t, "DOW") or str.contains(t, "US500") or str.contains(t, "SPX") or
            str.contains(t, "US100") or str.contains(t, "JP225") or str.contains(t, "UK100") or str.contains(t,
                "DAX") or str.contains(t, "CAC")
        inst := "مؤشرات (NAS/DOW)"
    // فوركس ين (6 أرقام)
    else if str.contains(t, "JPY")
        inst := "فوركس (6 أرقام)"
    inst

string autoInstrument = getAutoInstrument()

//══════════════════════════════════════════════════════════════════════════════

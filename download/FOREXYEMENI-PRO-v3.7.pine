buildReSLA() =>
    float lp = math.abs(reE - reSL)
    float ld = pnlD(reLot, lp)
    string m = "╔════════════════════════════════╗\n"
    m += "║ ❌ ضرب وقف التعويض ║\n"
    m += "╚══════════════════════════════════════════╝\n\n"
    m += "📌 " + syminfo.ticker + " | ♻️ التعويض\n"
    m += "❌ الوقف: " + str.tostring(reSL, format.mintick) + " | -" + str.tostring(math.round(lp,2),"#.##") + " نقطة\n"
    m += "💰 الخسارة: $" + str.tostring(math.round(ld,2),"#.##") + "\n\n"
    m += SEP + "\n" + buildTPStatusRe() + SEP + "\n"
    if reR >= 1
        m += "💰 ربح جزئي ✅\n"
    m += "📱 t.me/forexYemeni_Gold"
    m

//═══════════════════════════════════════════════
//  12. فلاتر التأكيد
//═══════════════════════════════════════════════
float rsiV  = ta.rsi(close, rsiLen)
float rATR  = ta.atr(length)
float atrPc = rATR / close * 100.0

bool hasMom    = not useMom    or atrPc >= minATR
bool rsiBuyOK  = not useRSI    or rsiV  <  rsiBuyMax
bool rsiSellOK = not useRSI    or rsiV  >  rsiSellMin

float cH     = ta.highest(high, chopLen)
float cL     = ta.lowest (low,  chopLen)
bool  isChop = useChop and (cH - cL) < rATR * 2.0

bool inSess  = not useSession or timeframe.isdaily or timeframe.isweekly or timeframe.ismonthly or not na(time(timeframe.period, sessionStr, "UTC"))

float body  = math.abs(close - open)
float uShad = high - math.max(close, open)
float lShad = math.min(close, open) - low

bool bEng = useCandle and close[1] < open[1] and close > open and close > open[1] and open < close[1]
bool sEng = useCandle and close[1] > open[1] and close < open and close < open[1] and open > close[1]
bool ham  = useCandle and body > 0.0 and lShad > body*2.0 and uShad < body*0.5 and close > open
bool shot = useCandle and body > 0.0 and uShad > body*2.0 and lShad < body*0.5 and close < open

bool bCand = not useCandle or bEng or ham  or (close > open and close > high[1])
bool sCand = not useCandle or sEng or shot or (close < open and close < low[1])

passBuy() => hasMom and rsiBuyOK and bCand and not isChop and inSess
passSell() => hasMom and rsiSellOK and sCand and not isChop and inSess

//═══════════════════════════════════════════════
//  13. محرك السوبرترند والإشارات
//═══════════════════════════════════════════════
float atr = mult * ta.atr(length)
float hh  = useClose ? ta.highest(close, length) : ta.highest(high, length)
float ll  = useClose ? ta.lowest (close, length) : ta.lowest (low,  length)

float lS = hh - atr
float sS = ll + atr
float lP = nz(lS[1], lS)
float sP = nz(sS[1], sS)

lS  := (useClose ? close : high) > lP ? math.max(lS, lP) : lS
sS  := (useClose ? close : low)  < sP ? math.min(sS, sP) : sS
dir := high > sP ? 1 : low < lS ? -1 : dir

bool rawB = dir == 1  and dir[1] == -1
bool rawS = dir == -1 and dir[1] == 1

// ── Pullback ──
bool nearLS = false
bool nearSS = false
for i = 1 to pbBars
    float dL = math.abs(nz(close[i], 0.0) - nz(lS[i], 0.0))
    float dS = math.abs(nz(close[i], 0.0) - nz(sS[i], 0.0))
    if dL <= pbDist * rATR
        nearLS := true
    if dS <= pbDist * rATR
        nearSS := true

bool pullB_cond = usePullback and dir==1  and dir[1]==1  and nearLS and close>open and close>lS
bool pullS_cond = usePullback and dir==-1 and dir[1]==-1 and nearSS and close<open and close<sS
bool pullB = pullB_cond and not pullB_cond[1]
bool pullS = pullS_cond and not pullS_cond[1]

// ── Level ──
bool lvlB_cond = useLevel and dir==1  and (nBF or nBOB or bSw or (not na(lpl) and low>=lpl*0.999 and close>lpl)) and close > open
bool lvlS_cond = useLevel and dir==-1 and (nBR or nROB or bSe or (not na(lph) and high<=lph*1.001 and close<lph)) and close < open
bool lvlB = lvlB_cond and not lvlB_cond[1]
bool lvlS = lvlS_cond and not lvlS_cond[1]

bool anyB = (useCross and rawB) or pullB or lvlB
bool anyS = (useCross and rawS) or pullS or lvlS

// ── تقييم النجوم ──
int    cStars   = 0
string cSigType = ""
if anyB or anyS
    cStars := 1
    if anyB
        cSigType := rawB ? "تقاطع" : pullB ? "سحب" : "مستوى"
        if htfTr == 1
            cStars += 1
        if nBF or bSw or nBOB
            cStars := math.min(cStars + 1, 3)
    else
        cSigType := rawS ? "تقاطع" : pullS ? "سحب" : "مستوى"
        if htfTr == -1
            cStars += 1
        if nBR or bSe or nROB
            cStars := math.min(cStars + 1, 3)

//═══════════════════════════════════════════════
//  14. حذف الرسومات
//═══════════════════════════════════════════════
clrM() =>
    if not na(eL)
        line.delete(eL)
    if not na(slL)
        line.delete(slL)
    if not na(eLb)
        label.delete(eLb)
    if not na(slLb)
        label.delete(slLb)
    int szL = array.size(tpL)
    if szL > 0
        for j = 0 to szL - 1
            line.delete(array.get(tpL, j))
    int szLb = array.size(tpLb)
    if szLb > 0
        for j = 0 to szLb - 1
            label.delete(array.get(tpLb, j))

clrP() =>
    if not na(pyEL)
        line.delete(pyEL)
    if not na(pySLL)
        line.delete(pySLL)
    if not na(pyELb)
        label.delete(pyELb)
    if not na(pySLb)
        label.delete(pySLb)
    int szL = array.size(pyTL)
    if szL > 0
        for j = 0 to szL - 1
            line.delete(array.get(pyTL, j))
    int szLb = array.size(pyTLb)
    if szLb > 0
        for j = 0 to szLb - 1
            label.delete(array.get(pyTLb, j))

clrR() =>
    if not na(reEL)
        line.delete(reEL)
    if not na(reSLL)
        line.delete(reSLL)
    if not na(reELb)
        label.delete(reELb)
    if not na(reSLb)
        label.delete(reSLb)
    int szL = array.size(reTL)
    if szL > 0
        for j = 0 to szL - 1
            line.delete(array.get(reTL, j))
    int szLb = array.size(reTLb)
    if szLb > 0
        for j = 0 to szLb - 1
            label.delete(array.get(reTLb, j))

clrAll() =>
    clrM()
    clrP()
    clrR()

//═══════════════════════════════════════════════
//  15. دالة لون نسبة النجاح
//═══════════════════════════════════════════════
wrC(float pct) => pct >= 60.0 ? cG : pct >= 40.0 ? cAu : cR

//═══════════════════════════════════════════════
//  16. مراقبة الصفقة الرئيسية
//═══════════════════════════════════════════════
if inT
    int tpSzM = array.size(tpP)
    if tpSzM > 0
        for i = 0 to tpSzM - 1
            if not array.get(tpS, i)
                float t = array.get(tpP, i)
                if (isBuy and high >= t) or (not isBuy and low <= t)
                    array.set(tpS, i, true)
                    mxTPR := math.max(mxTPR, i + 1)
                    label.set_text(array.get(tpLb, i), "✅TP" + str.tostring(i+1))

                    // تأمين تلقائي عند TP1
                    if i == 0 and not beSent
                        float bv  = beBufPx()
                        float nBE = isBuy ? ep + bv : ep - bv
                        if (isBuy and sl < nBE) or (not isBuy and sl > nBE)
                            sl := nBE
                            beSent := true
                            line.set_y1(slL, sl)
                            line.set_y2(slL, sl)
                            label.set_y(slLb, sl)
                            label.set_text(slLb, "🛡️" + str.tostring(sl, format.mintick))
                            label.set_color(slLb, cGr)
                            line.set_color(slL,  cGr)
                            alert(buildBE(), alert.freq_all)

                    // تنبيه TP
                    if mxTPR > laTP2
                        bool isJump = (mxTPR - laTP2) > 1
                        alert(buildTPA(mxTPR, isJump), alert.freq_all)
                        if mxTPR == numTP
                            if not tradeCnt
                                winT     += 1
                                totT     += 1
                                tradeCnt := true
                                array.push(tCTime, entryTime)
                                array.push(tCWin,  1)
                            inT      := false
                            lastSig  := 0
                            inPy     := false
                            pyrSent  := false
                            beSent   := false
                            clrAll()
                            lastExit := bar_index
                        laTP2 := mxTPR

                    // وقف تتبعي
                    if useTrail and mxTPR > 1 and inT and array.size(tpP) > 0
                        float nSL = array.get(tpP, mxTPR - 2)
                        if (isBuy and nSL > sl) or (not isBuy and nSL < sl)
                            sl := nSL
                            line.set_y1(slL, sl)
                            line.set_y2(slL, sl)
                            label.set_y(slLb, sl)
                            label.set_text(slLb, "🔄" + str.tostring(sl, format.mintick))
                            label.set_color(slLb, cGr)
                            line.set_color(slL,  cGr)
                else
                    break

    bool slH = (isBuy and low <= sl) or (not isBuy and high >= sl)
    if slH and not slSent and inT
        alert(buildSLA(), alert.freq_all)
        slSent := true
        if not tradeCnt
            if mxTPR >= 1
                winT += 1
            else
                lossT += 1
            totT     += 1
            tradeCnt := true
            array.push(tCTime, entryTime)
            array.push(tCWin,  mxTPR >= 1 ? 1 : 0)
        if useReentry and mxTPR == 0
            bool ok = (isBuy     and htfTr ==  1 and smcT ==  1) or (not isBuy and htfTr == -1 and smcT == -1)
            if ok
                pendRe  := true
                isBuyRe := isBuy
        inT     := false
        lastSig := 0
        inPy    := false
        pyrSent := false
        beSent  := false
        clrAll()
        lastExit := bar_index

//═══════════════════════════════════════════════
//  17. فتح التعزيز (Pyramid)
//═══════════════════════════════════════════════
if inT and not inPy and not inRe and usePyr and mxTPR >= pyrTP and not pyrSent
    pyrSent  := true
    pyrR     := 0
    pyrLA    := 0
    inPy     := true
    pyrSLAS  := false
    pyE      := close
    pyA      := tATR

    float pSD = math.max(math.abs(pyE - sl), syminfo.mintick)

    if pyrSLM == "آخر محقق"
        float lastT = array.size(tpP) > mxTPR - 1 ? array.get(tpP, mxTPR - 1) : ep
        pySL := isBuy ? math.min(lastT, pyE - pSD*0.5) : math.max(lastT, pyE + pSD*0.5)
    else if pyrSLM == "ATR"
        pySL := isBuy ? pyE - pyA : pyE + pyA
    else
        pySL := isBuy ? math.min(ep, pyE - pyA) : math.max(ep, pyE + pyA)

    if isBuy     and pySL >= pyE
        pySL := pyE - pyA
    if not isBuy and pySL <= pyE
        pySL := pyE + pyA

    float pRisk = bal * riskP / 100.0
    pyLot := calcLot(pRisk, math.abs(pyE - pySL))

    pyEL  := line.new(bar_index, pyE,  bar_index+1, pyE, extend=extend.right, color=cP, width=2)
    pyELb := label.new(bar_index, pyE,  "🔥" + str.tostring(pyE,  format.mintick), style=label.style_label_left, color=cP, textcolor=color.white, size=size.small)
    pySLL := line.new(bar_index, pySL, bar_index+1, pySL, extend=extend.right, color=cR, width=2, style=line.style_dashed)
    pySLb := label.new(bar_index, pySL, "🛑" + str.tostring(pySL, format.mintick), style=label.style_label_left, color=cR, textcolor=color.white, size=size.small)

    array.clear(pyTP)
    array.clear(pyTL)
    array.clear(pyTLb)
    array.clear(pyTS)

    float pySD = math.abs(pyE - pySL)
    for j = 0 to pyrTP - 1
        float pt  = isBuy ? pyE + pySD*pyrRR*(j+1) : pyE - pySD*pyrRR*(j+1)
        color tc  = array.get(tpC, math.min(j, 9))
        line  tl  = line.new(bar_index, pt, bar_index+1, pt, extend=extend.right, color=tc, width=1)
        label tlb = label.new(bar_index, pt, "🔥TP" + str.tostring(j+1) + ":" + str.tostring(pt, format.mintick), style=label.style_label_left, color=tc, textcolor=color.white, size=size.small)
        array.push(pyTL,  tl)
        array.push(pyTLb, tlb)
        array.push(pyTP,  pt)
        array.push(pyTS,  false)

    alert(buildPyrEnt(), alert.freq_all)

// ── مراقبة أهداف التعزيز ──
if inPy
    int pySzT = array.size(pyTP)
    if pySzT > 0
        for i = 0 to pySzT - 1
            if not array.get(pyTS, i)
                float t = array.get(pyTP, i)
                if (isBuy and high >= t) or (not isBuy and low <= t)
                    array.set(pyTS, i, true)
                    pyrR := math.max(pyrR, i + 1)
                    label.set_text(array.get(pyTLb, i), "✅🔥TP" + str.tostring(i+1))
                    if pyrR > pyrLA
                        alert(buildPyrTPA(pyrR), alert.freq_all)
                        if pyrR == pyrTP
                            inPy := false
                            clrP()
                        pyrLA := pyrR
                else
                    break

    bool pySLH = (isBuy and low <= pySL) or (not isBuy and high >= pySL)
    if pySLH and not pyrSLAS and inPy
        alert(buildPyrSLA(), alert.freq_all)
        pyrSLAS := true
        inPy    := false
        clrP()

//═══════════════════════════════════════════════
//  18. مراقبة التعويض (Reentry)
//═══════════════════════════════════════════════
if pendRe and not inT and not inRe and not inPy and barstate.isconfirmed
    bool canRe = isBuyRe ? (anyB and passBuy()) : (anyS and passSell())
    if canRe
        pendRe  := false
        reCnt   := false
        reR     := 0
        reLA    := 0
        reSLS   := false
        inRe    := true
        reE     := close
        reA     := tATR
        reSL    := isBuyRe ? reE - (reA * reMult) : reE + (reA * reMult)

        float minSD = tATR * 0.5
        if math.abs(reE - reSL) < minSD
            reSL := isBuyRe ? reE - minSD : reE + minSD

        float reRisk = bal * riskP / 100.0
        reLot := calcLot(reRisk, math.abs(reE - reSL))

        reEL  := line.new(bar_index, reE,  bar_index+1, reE, extend=extend.right, color=cCy, width=2)
        reELb := label.new(bar_index, reE,  "♻️" + str.tostring(reE,  format.mintick), style=label.style_label_left, color=cCy, textcolor=color.white, size=size.small)
        reSLL := line.new(bar_index, reSL, bar_index+1, reSL, extend=extend.right, color=cR, width=2, style=line.style_dashed)
        reSLb := label.new(bar_index, reSL, "🛑" + str.tostring(reSL, format.mintick), style=label.style_label_left, color=cR, textcolor=color.white, size=size.small)

        array.clear(reTP)
        array.clear(reTL)
        array.clear(reTLb)
        array.clear(reTS)

        float reSD = math.abs(reE - reSL)
        for j = 0 to reTPn - 1
            float rt  = isBuyRe ? reE + reSD*reRR*(j+1) : reE - reSD*reRR*(j+1)
            color tc  = array.get(tpC, math.min(j, 9))
            line  tl  = line.new(bar_index, rt, bar_index+1, rt, extend=extend.right, color=tc, width=1)
            label tlb = label.new(bar_index, rt, "♻️TP" + str.tostring(j+1) + ":" + str.tostring(rt, format.mintick), style=label.style_label_left, color=tc, textcolor=color.white, size=size.small)
            array.push(reTL,  tl)
            array.push(reTLb, tlb)
            array.push(reTP,  rt)
            array.push(reTS,  false)

        alert(buildReEnt(), alert.freq_all)

if inRe
    int reSzT = array.size(reTP)
    if reSzT > 0
        for i = 0 to reSzT - 1
            if not array.get(reTS, i)
                float t = array.get(reTP, i)
                if (isBuyRe and high >= t) or (not isBuyRe and low <= t)
                    array.set(reTS, i, true)
                    reR := math.max(reR, i + 1)
                    label.set_text(array.get(reTLb, i), "✅♻️TP" + str.tostring(i+1))
                    if reR > reLA
                        alert(buildReTPA(reR), alert.freq_all)
                        if reR == reTPn
                            if not reCnt
                                reWin += 1
                                reCnt := true
                            inRe := false
                            clrR()
                        reLA := reR
                else
                    break

    bool reSLH = (isBuyRe and low <= reSL) or (not isBuyRe and high >= reSL)
    if reSLH and not reSLS and inRe
        alert(buildReSLA(), alert.freq_all)
        reSLS := true
        if not reCnt
            reLoss += 1
        inRe := false
        clrR()

//═══════════════════════════════════════════════
//  19. فتح الصفقة الجديدة
//═══════════════════════════════════════════════
int  cooldownBars = useCooldown ? 3 : 1
bool isCooldownOK = bar_index > lastExit + cooldownBars

bool newB = anyB and cStars >= minStars and passBuy()  and lastSig !=  1 and not inT and not inRe and not pendRe and barstate.isconfirmed and isCooldownOK and not na(atr)
bool newS = anyS and cStars >= minStars and passSell() and lastSig != -1 and not inT and not inRe and not pendRe and barstate.isconfirmed and isCooldownOK and not na(atr)

plotshape(showEntryMark and newB, title="شراء",  text="BUY", style=shape.labelup, location=location.belowbar, color=color.new(#00E676,20), textcolor=color.white, size=size.small)
plotshape(showEntryMark and newS, title="بيع",   text="SELL", style=shape.labeldown, location=location.abovebar, color=color.new(#FF5252,20), textcolor=color.white, size=size.small)

if newB or newS
    tradeCnt := false
    mxTPR    := 0
    laTP2    := 0
    slSent   := false
    beSent   := false
    inPy     := false
    pyrSent  := false
    pyrR     := 0
    pyrLA    := 0
    pendRe   := false
    reCnt    := false
    clrM()
    clrP()
    clrR()
    array.clear(tpP)
    array.clear(tpL)
    array.clear(tpLb)
    array.clear(tpS)
    array.clear(pyTP)
    array.clear(pyTL)
    array.clear(pyTLb)
    array.clear(pyTS)
    array.clear(reTP)
    array.clear(reTL)
    array.clear(reTLb)
    array.clear(reTS)

    ep       := close
    tATR     := atr
    isBuy    := newB
    inT      := true
    stars    := cStars
    sigType  := cSigType
    lastSig  := newB ? 1 : -1
    entryTime := time

    // ── حساب الوقف ──
    float cSL      = float(na)
    float minSlDist = tATR * 0.5
    if slMode == "ATR"
        cSL := isBuy ? ep - tATR * slMult : ep + tATR * slMult
    else if slMode == "Swing"
        cSL := isBuy ? (na(lpl) ? ep - tATR : math.min(ep - minSlDist, lpl - tATR*0.2)) : (na(lph) ? ep + tATR : math.max(ep + minSlDist, lph + tATR*0.2))
    else
        cSL := isBuy ? (na(bfb) ? ep - tATR : math.min(ep - minSlDist, bfb - tATR*0.2)) : (na(brt) ? ep + tATR : math.max(ep + minSlDist, brt + tATR*0.2))

    sl   := cSL
    iSL  := sl
    float sD = math.max(math.abs(ep - iSL), syminfo.mintick)
    float tR = bal * riskP / 100.0
    sLot   := calcLot(tR, sD)
    sRisk  := pnlD(sLot, sD)
    sIsBuy := isBuy

    eL   := line.new(bar_index, ep, bar_index+1, ep, extend=extend.right, color=cO, width=3)
    eLb  := label.new(bar_index, ep, (isBuy ? "🚀" : "🔻") + str.tostring(ep, format.mintick), style=label.style_label_left, color=cO, textcolor=color.white)
    slL  := line.new(bar_index, sl, bar_index+1, sl, extend=extend.right, color=cR, width=2, style=line.style_dashed)
    slLb := label.new(bar_index, sl, "🛑" + str.tostring(sl, format.mintick), style=label.style_label_left, color=cR, textcolor=color.white, size=size.small)

    // ── الأهداف ──
    float[] fibs = array.from(0.382, 0.618, 0.786, 1.0, 1.272, 1.618, 2.0, 2.618, 3.618, 4.236)
    float[] vSw  = array.new_float()

    if tpMode == "Swings"
        if isBuy
            for idx = 0 to array.size(rPH) - 1
                float p = array.get(rPH, idx)
                if p > ep
                    bool dup = false
                    for v in vSw
                        if v == p
                            dup := true
                            break
                    if not dup
                        array.push(vSw, p)
            array.sort(vSw)
        else
            for idx = 0 to array.size(rPL) - 1
                float p = array.get(rPL, idx)
                if p < ep
                    bool dup = false
                    for v in vSw
                        if v == p
                            dup := true
                            break
                    if not dup
                        array.push(vSw, p)
            array.sort(vSw, order.descending)

    for i = 0 to numTP - 1
        float t = float(na)
        if tpMode == "RR"
            t := isBuy ? ep + sD*(i+1) : ep - sD*(i+1)
        else if tpMode == "Fib"
            t := isBuy ? ep + sD*array.get(fibs, math.min(i,9)) : ep - sD*array.get(fibs, math.min(i,9))
        else if tpMode == "Swings"
            t := array.size(vSw) > i ? array.get(vSw, i) : (isBuy ? ep + sD*(i+1) : ep - sD*(i+1))
        else
            t := isBuy ? ep + tATR*(1.0 + float(i)*0.5) : ep - tATR*(1.0 + float(i)*0.5)

        color tc  = array.get(tpC, math.min(i, 9))
        line  tl  = line.new(bar_index, t, bar_index+1, t, extend=extend.right, color=tc, width=1)
        label tlb = label.new(bar_index, t, "TP" + str.tostring(i+1) + ":" + str.tostring(t, format.mintick), style=label.style_label_left, color=tc, textcolor=color.white, size=size.small)
        array.push(tpL,  tl)
        array.push(tpLb, tlb)
        array.push(tpP,  t)
        array.push(tpS,  false)
        if i == numTP - 1
            mxTP := t

    alert(buildEnt(), alert.freq_all)

//═══════════════════════════════════════════════
//  20. رسم السوبرترند والخلفية
//═══════════════════════════════════════════════
float sTLine = dir == 1 ? sS : lS
color sTColor = dir == 1 ? color.new(#00E676,20) : color.new(#FF5252,20)
plot(showSTLine ? sTLine : na, "SuperTrend", color=sTColor, linewidth=2, style=plot.style_linebr)
bgcolor(showTradeBG and inT ? (isBuy ? color.new(#00E676,93) : color.new(#FF5252,93)) : na, title="Trade Background")

//═══════════════════════════════════════════════
//  21. لوحة الإحصائيات
//═══════════════════════════════════════════════
var table d = table.new(position.top_right, 2, 16, border_width=1, border_color=color.new(color.gray,80), frame_color=color.new(#333333,0), frame_width=2)

if barstate.islast
    int pTrades  = 0
    int pWins    = 0
    int nowT     = time
    int currentY = year(nowT,         "Asia/Riyadh")
    int currentM = month(nowT,        "Asia/Riyadh")
    int currentD = dayofmonth(nowT,   "Asia/Riyadh")

    int szStat = array.size(tCTime)
    if szStat > 0
        for i = 0 to szStat - 1
            int  ft      = array.get(tCTime, i)
            int  fw      = array.get(tCWin,  i)
            bool isMatch = false

            if statPeriod == "اليوم الحالي (مكة)"
                if year(ft,"Asia/Riyadh") == currentY and month(ft,"Asia/Riyadh") == currentM and dayofmonth(ft,"Asia/Riyadh") == currentD
                    isMatch := true
            else if statPeriod == "آخر 7 أيام"
                if nowT - ft <= 604800000
                    isMatch := true
            else if statPeriod == "آخر 30 يوم"
                if nowT - ft <= 2592000000
                    isMatch := true
            else
                isMatch := true

            if isMatch
                pTrades += 1
                pWins   += fw

    if array.size(tCTime) > 500
        array.shift(tCTime)
        array.shift(tCWin)

    color hc   = htfTr == 1  ? cG  : cR
    color sc   = smcT  == 1  ? cG  : cR
    float pWR  = pTrades > 0 ? pWins * 100.0 / pTrades : 0.0

    table.cell(d, 0, 0,  "🔥 FYP-PRO v3.7 🔥", text_color=cAu, text_size=size.normal, bgcolor=color.new(#222222,0), text_halign=text.align_center)
    table.cell(d, 1, 0,  "💎 DAY TRADER", text_color=cGr, text_size=size.small, bgcolor=color.new(#222222,0))

    table.cell(d, 0, 1,  "🏦 الأداة",   text_color=cGr, text_size=size.small,  bgcolor=cBG)
    table.cell(d, 1, 1,  instShort,     text_color=cCy, text_size=size.tiny,   bgcolor=cBG)
    table.cell(d, 0, 2,  "💰 الرصيد",   text_color=cGr, text_size=size.small,  bgcolor=cBG)
    table.cell(d, 1, 2,  "$" + str.tostring(bal,"#.##"), text_color=color.white, text_size=size.small, bgcolor=cBG)
    table.cell(d, 0, 3,  "📦 اللوت",    text_color=cGr, text_size=size.small, bgcolor=cBG)
    table.cell(d, 1, 3,  sLot >= 0.01 ? lotStr(sLot) : "---", text_color=inT ? (sIsBuy ? cG : cR) : cGr, text_size=size.small, bgcolor=cBG)

    string fs = isChop ? "⚠️تذبذب" : not hasMom ? "⚠️زخم ضعيف" : not inSess ? "⏸️خارج جلسة" : "✅نشط"
    color  fc = isChop ? cR : not hasMom ? cAu : cG
    table.cell(d, 0, 4,  "🔍 الفلاتر",  text_color=cGr, text_size=size.small, bgcolor=cBG)
    table.cell(d, 1, 4,  fs,            text_color=fc,  text_size=size.small, bgcolor=cBG)

    table.cell(d, 0, 5,  "📈 MTF",      text_color=cGr, text_size=size.small, bgcolor=cBG)
    table.cell(d, 1, 5,  htfD + (htfTr==1 ? "🐂" : "🐻"), text_color=hc, text_size=size.small, bgcolor=cBG)
    table.cell(d, 0, 6,  "🏗️ SMC",      text_color=cGr, text_size=size.small, bgcolor=cBG)
    table.cell(d, 1, 6,  smcT==1 ? "صاعد" : smcT==-1 ? "هابط" : "محايد", text_color=sc, text_size=size.small, bgcolor=cBG)

    string ts  = not inT and not inRe ? "لا توجد" : inT and inPy ? "رئيسية+تعزيز🔥" : inT ? "نشطة⏳" : inRe ? "تعويض♻️" : pendRe ? "انتظار♻️" : "---"
    color  tsc = not inT and not inRe ? cGr : inT and inPy ? cP : inT ? cAu : inRe ? cCy : cGr
    table.cell(d, 0, 7,  "⏳ الحالة",   text_color=cGr, text_size=size.small, bgcolor=cBG)
    table.cell(d, 1, 7,  ts,            text_color=tsc, text_size=size.small, bgcolor=cBG)

    string td = inT ? str.tostring(mxTPR) + "/" + str.tostring(numTP) : inRe ? "♻️" + str.tostring(reR) + "/" + str.tostring(reTPn) : inPy ? "🔥" + str.tostring(pyrR) + "/" + str.tostring(pyrTP) : "---"
    table.cell(d, 0, 8,  "🎯 الأهداف",  text_color=cGr, text_size=size.small, bgcolor=cBG)
    table.cell(d, 1, 8,  td,            text_color=cCy, text_size=size.small, bgcolor=cBG)

    table.cell(d, 0, 9,  "📊══════════════", text_color=cAu, text_size=size.tiny, bgcolor=color.new(#444444,0), text_halign=text.align_center)
    table.cell(d, 1, 9,  "════════════📊", text_color=cAu, text_size=size.tiny, bgcolor=color.new(#444444,0), text_halign=text.align_center)

    table.cell(d, 0, 10, "📅 الفترة",   text_color=cGr, text_size=size.small, bgcolor=cBG)
    table.cell(d, 1, 10, statPeriod,    text_color=cCy, text_size=size.small, bgcolor=cBG)

    table.cell(d, 0, 11, "📊 الصفقات",  text_color=cGr, text_size=size.small, bgcolor=cBG)
    table.cell(d, 1, 11, str.tostring(pTrades) + " صفقة | " + str.tostring(pWins) + "✅", text_color=color.white, text_size=size.small, bgcolor=cBG)

    table.cell(d, 0, 12, "🎯 نسبة النجاح", text_color=cGr, text_size=size.small, bgcolor=cBG)
    table.cell(d, 1, 12, str.tostring(math.round(pWR,1),"#.#") + "%", text_color=wrC(pWR), text_size=size.large, bgcolor=cBG)

    table.cell(d, 0, 13, "♻️ التعويض",  text_color=cGr, text_size=size.small, bgcolor=cBG)
    table.cell(d, 1, 13, str.tostring(reWin) + "✅ " + str.tostring(reLoss) + "❌", text_color=cCy, text_size=size.small, bgcolor=cBG)

    table.cell(d, 0, 14, "⏰ الجلسة",   text_color=cGr, text_size=size.small, bgcolor=cBG)
    table.cell(d, 1, 14, inSess ? "✅ نشطة" : "⏸️ خارج", text_color=inSess ? cG : cR, text_size=size.small, bgcolor=cBG)

    table.cell(d, 0, 15, "🔀 سوبرترند", text_color=cGr, text_size=size.small, bgcolor=cBG)
    table.cell(d, 1, 15, dir==1 ? "🟢 صاعد" : "🔴 هابط", text_color=dir==1 ? cG : cR, text_size=size.small, bgcolor=cBG)

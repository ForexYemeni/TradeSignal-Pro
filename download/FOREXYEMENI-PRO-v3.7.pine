//@version=5
indicator("FOREXYEMENI-PRO-v3.7", shorttitle="FYP-v3.7", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=100)

//═══════════════════════════════════════════════
//  1. HTF تلقائي
//═══════════════════════════════════════════════
getHTF() =>
    string r = ""
    if timeframe.isseconds
        r := "5"
    else if timeframe.isminutes
        if timeframe.multiplier <= 1
            r := "15"
        else if timeframe.multiplier <= 5
            r := "60"
        else if timeframe.multiplier <= 15
            r := "240"
        else if timeframe.multiplier <= 60
            r := "D"
        else
            r := "W"
    else if timeframe.isdaily
        r := "W"
    else if timeframe.isweekly
        r := "M"
    else
        r := "D"
    r

string autoHTF = getHTF()

htfName(string tf) =>
    tf == "60" ? "1س" : tf == "240" ? "4س" : tf == "D" ? "يومي" : tf == "W" ? "أسبوعي" : tf

//═══════════════════════════════════════════════
//  2. الإعدادات
//═══════════════════════════════════════════════
grp1 = "1️⃣ الإعدادات الأساسية"
length = input.int(22, "📏 طول ATR", group=grp1)
mult = input.float(2.0, "🔄 معامل ATR", step=0.1, group=grp1)
useClose = input.bool(true, "🕯️ إغلاق للقمم/القيعان", group=grp1)

grp2 = "2️⃣ فلاتر الدخول والسيولة"
useCooldown  = input.bool(false, "❄️ تفعيل نظام التبريد", group=grp2)
useCross     = input.bool(true,  "🔀 تقاطع السوبرترند", group=grp2)
usePullback  = input.bool(true,  "🔄 سحب + استمرار", group=grp2)
useLevel     = input.bool(true,  "📐 ارتداد مستويات", group=grp2)
pbBars       = input.int(5,      "🕯️ شموع السحب", minval=2, maxval=15, group=grp2)
pbDist       = input.float(0.3,  "📏 مسافة السحب (×ATR)", step=0.05, group=grp2)
useRSI       = input.bool(false, "📊 تفعيل RSI", group=grp2)
rsiLen       = input.int(14,     "📏 طول RSI", group=grp2)
rsiBuyMax    = input.float(55.0, "📈 RSI شراء أقل من", group=grp2)
rsiSellMin   = input.float(45.0, "📉 RSI بيع أعلى من", group=grp2)
useMom       = input.bool(false, "🚀 زخم ATR", group=grp2)
minATR       = input.float(0.01, "📊 ATR أدنى %", step=0.01, group=grp2)
useCandle    = input.bool(false, "🕯️ أنماط الشموع", group=grp2)
useChop      = input.bool(false, "🌊 ضد التذبذب", group=grp2)
chopLen      = input.int(14,     "📏 طول التذبذب", group=grp2)
useSession   = input.bool(false, "🕐 فلتر الجلسات", group=grp2)
sessionStr   = input.session("0700-2100", "🌍 الجلسة النشطة (UTC)", group=grp2)
useAutoHTF   = input.bool(true,  "🤖 HTF تلقائي", group=grp2)
manualHTF    = input.timeframe("60", "⏱️ HTF يدوي", group=grp2)
smcLen       = input.int(3,      "🎯 حساسية SMC", minval=1, group=grp2)
minStars     = input.int(1,      "⭐ حد أدنى نجوم", minval=1, maxval=3, group=grp2)
showFVG      = input.bool(true,  "📦 إظهار FVG", group=grp2)
showOB       = input.bool(true,  "🧱 إظهار OB", group=grp2)
showSR       = input.bool(true,  "📊 دعم/مقاومة", group=grp2)

string htf  = useAutoHTF ? autoHTF : manualHTF
string htfD = useAutoHTF ? htfName(autoHTF) : htfName(manualHTF)

grp3 = "3️⃣ الأهداف والوقف"
numTP   = input.int(10,    "🔢 عدد الأهداف", minval=1, maxval=10, group=grp3)
tpMode  = input.string("Fib", "📐 نوع الأهداف", options=["ATR","RR","Fib","Swings"], group=grp3)
slMode  = input.string("ATR", "🛑 نوع الوقف",   options=["ATR","Swing","FVG"],       group=grp3)
slMult  = input.float(1.0,  "➗ مضاعف الوقف", step=0.1, group=grp3)
beBuf   = input.float(0.5,  "🛡️ هامش التأمين (نقاط)", step=0.1, group=grp3)
useTrail = input.bool(false, "🚀 وقف تتبعي", group=grp3)

grp4 = "4️⃣ التعزيز والتعويض"
useReentry = input.bool(false, "♻️ صفقة تعويض", group=grp4)
reMult     = input.float(1.5,  "➗ مضاعف وقف التعويض", group=grp4)
reRR       = input.float(2.0,  "🎯 R:R تعويض", group=grp4)
reTPn      = input.int(5,      "🔢 أهداف تعويض", minval=1, maxval=10, group=grp4)
usePyr     = input.bool(true,  "🔥 تعزيز", group=grp4)
pyrTP      = input.int(3,      "🔢 أهداف تعزيز", minval=1, maxval=5, group=grp4)
pyrSLM     = input.string("آخر محقق", "🛑 وقف التعزيز", options=["آخر محقق","ATR","أصلي"], group=grp4)
pyrRR      = input.float(1.5,  "🎯 R:R تعزيز", group=grp4)

grp5 = "5️⃣ إدارة المخاطر"
bal   = input.float(1000.0, "💵 الرصيد ($)", step=100, minval=1, group=grp5)
riskP = input.float(1.0,    "⚠️ المخاطرة %", step=0.1, minval=0.1, maxval=100, group=grp5)

grp6 = "6️⃣ الإحصائيات والمظهر"
statPeriod    = input.string("اليوم الحالي (مكة)", "📅 فترة الإحصائيات", options=["اليوم الحالي (مكة)","آخر 7 أيام","آخر 30 يوم","كل البيانات"], group=grp6)
showSTLine    = input.bool(true,  "📈 خط السوبرترند", group=grp6)
showTradeBG   = input.bool(true,  "🎨 خلفية الصفقة",  group=grp6)
showEntryMark = input.bool(true,  "📍 علامة الدخول",  group=grp6)

//═══════════════════════════════════════════════
//  3. كشف الأداة
//═══════════════════════════════════════════════
getInst() =>
    string t = syminfo.ticker
    string r = "فوركس"
    if str.contains(t,"XAU") or str.contains(t,"GOLD")
        r := "الذهب (XAUUSD)"
    else if str.contains(t,"XAG") or str.contains(t,"SILVER")
        r := "الفضة (XAGUSD)"
    else if str.contains(t,"BTC") or str.contains(t,"ETH") or str.contains(t,"SOL") or str.contains(t,"BNB") or str.contains(t,"XRP") or str.contains(t,"ADA") or str.contains(t,"DOGE") or str.contains(t,"DOT") or str.contains(t,"USDT")
        r := "عملات رقمية"
    else if str.contains(t,"NAS") or str.contains(t,"US30") or str.contains(t,"DAX") or str.contains(t,"US500") or str.contains(t,"SPX") or str.contains(t,"NDX")
        r := "مؤشرات (NAS/DOW)"
    else if str.contains(t,"JPY")
        r := "فوركس (6 أرقام)"
    r

string inst = getInst()

getInstShort() =>
    string t = syminfo.ticker
    string r = "فوركس"
    if str.contains(t,"XAU") or str.contains(t,"GOLD")
        r := "🥇 ذهب"
    else if str.contains(t,"XAG") or str.contains(t,"SILVER")
        r := "🥈 فضة"
    else if str.contains(t,"BTC") or str.contains(t,"ETH") or str.contains(t,"SOL")
        r := "₿ كريبتو"
    else if str.contains(t,"NAS") or str.contains(t,"US30") or str.contains(t,"DAX")
        r := "📊 مؤشرات"
    else if str.contains(t,"JPY")
        r := "💱 فوركس JPY"
    r

string instShort = getInstShort()

